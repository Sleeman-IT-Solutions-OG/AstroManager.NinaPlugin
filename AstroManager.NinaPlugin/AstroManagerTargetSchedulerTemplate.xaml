<ResourceDictionary
    x:Class="AstroManager.NinaPlugin.AstroManagerTargetSchedulerTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:AstroManager.NinaPlugin"
    xmlns:controls="clr-namespace:AstroManager.NinaPlugin.Controls"
    xmlns:mini="clr-namespace:NINA.View.Sequencer.MiniSequencer;assembly=NINA.Sequencer"
    xmlns:nina="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer"
    xmlns:ninactrl="clr-namespace:NINA.CustomControlLibrary;assembly=NINA.CustomControlLibrary"
    xmlns:behaviors="clr-namespace:NINA.Sequencer.Behaviors;assembly=NINA.Sequencer">

    <DataTemplate x:Key="AstroManagerSchedulerEventContainerTemplate">
        <Border
            MinHeight="50"
            Margin="0,10,0,0"
            Padding="0"
            Background="#1A1A1A"
            BorderBrush="#3C3C3C"
            BorderThickness="1">
            <Grid Background="#1A1A1A">
                <ItemsControl MinHeight="50" ItemsSource="{Binding Items}" />
                <TextBlock
                    Height="18"
                    MaxHeight="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    FontStyle="Italic"
                    Foreground="#707070"
                    Opacity="0.85"
                    Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContentControl}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <i:Interaction.Behaviors>
                    <behaviors:DragOverBehavior DragAboveSize="0" DragBelowSize="0" />
                    <behaviors:DropIntoBehavior AllowedDragDropTypesString="NINA.Sequencer.Container.ISequenceContainer;NINA.Sequencer.SequenceItem.ISequenceItem;NINA.Sequencer.TemplatedSequenceContainer" OnDropCommand="DropIntoCommand" />
                </i:Interaction.Behaviors>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="AstroManagerLegacySchedulerDetailTemplate">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                    <Border Background="#252526" CornerRadius="3" Padding="10,8" Margin="0,5,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="#C0C0C0"
                                Text="Config Override:"
                                ToolTip="Leave as 'Use Server Default' to use the default configuration set in AstroManager web UI" />

                            <ComboBox
                                Grid.Column="1"
                                MinWidth="200"
                                VerticalAlignment="Center"
                                Background="#3C3C3C"
                                DisplayMemberPath="Name"
                                FontSize="12"
                                Foreground="#E0E0E0"
                                ItemsSource="{Binding AvailableConfigurations}"
                                SelectedValue="{Binding SelectedConfigurationId, Mode=TwoWay}"
                                SelectedValuePath="Id" />

                            <Button
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                Padding="8,4"
                                VerticalAlignment="Center"
                                Background="#3C3C3C"
                                Command="{Binding RefreshConfigurationsCommand}"
                                Content="↻"
                                FontSize="12"
                                Foreground="#E0E0E0"
                                ToolTip="Refresh configurations from server" />
                        </Grid>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="3" Padding="10,6" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Target:" Foreground="#808080" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock
                                    Margin="4,0,12,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="#4EC9B0"
                                    Text="{Binding CurrentTargetName}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0" Orientation="Horizontal">
                                <TextBlock Text="PA:" Foreground="#808080" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="#D69D29"
                                    Text="{Binding CurrentPositionAngleDisplay}" />
                            </StackPanel>

                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontSize="10"
                                Foreground="#B0B0B0"
                                Text="{Binding StatusMessage}"
                                TextTrimming="CharacterEllipsis" />

                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <TextBlock Text="Exposures:" Foreground="#808080" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="#569CD6"
                                    Text="{Binding SessionExposuresTaken}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="#141414" CornerRadius="3" Padding="10,8" Margin="0,0,0,5">
                        <TextBlock
                            Foreground="#B0B0B0"
                            FontSize="10"
                            Text="Legacy scheduler instruction. Use AstroManager Scheduler Container for Deep Sky Object-style target context and plugin compatibility." />
                    </Border>

                    <Expander Header="Status Log" IsExpanded="False" Margin="0,0,0,5" Foreground="#C0C0C0" FontSize="11">
                        <Border Background="#1A1A1A" CornerRadius="3" Padding="5" MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding StatusLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="55" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" Text="{Binding LevelIcon}" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="10" Foreground="#707070" Text="{Binding FormattedTime}" />
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="10" Text="{Binding Message}" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#B0B0B0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                    <Setter Property="Foreground" Value="#E74C3C" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                    <Setter Property="Foreground" Value="#F39C12" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Success">
                                                                    <Setter Property="Foreground" Value="#27AE60" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Expander>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="AstroManagerSchedulerContainerDetailTemplate">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                    <Border Background="#252526" CornerRadius="3" Padding="10,8" Margin="0,5,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="#C0C0C0"
                                Text="Config Override:" />

                            <ComboBox
                                Grid.Column="1"
                                MinWidth="220"
                                VerticalAlignment="Center"
                                Background="#3C3C3C"
                                DisplayMemberPath="Name"
                                FontSize="12"
                                Foreground="#E0E0E0"
                                ItemsSource="{Binding AvailableConfigurations}"
                                SelectedValue="{Binding SelectedConfigurationId, Mode=TwoWay}"
                                SelectedValuePath="Id" />

                            <Button
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                Padding="8,4"
                                VerticalAlignment="Center"
                                Background="#3C3C3C"
                                Command="{Binding RefreshConfigurationsCommand}"
                                Content="↻"
                                FontSize="12"
                                Foreground="#E0E0E0"
                                ToolTip="Refresh configurations from server" />
                        </Grid>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="3" Padding="10,6" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Target:" Foreground="#808080" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock
                                    Margin="4,0,12,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="#4EC9B0"
                                    Text="{Binding CurrentTargetName}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0" Orientation="Horizontal">
                                <TextBlock Text="PA:" Foreground="#808080" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="#D69D29"
                                    Text="{Binding CurrentPositionAngleDisplay}" />
                            </StackPanel>

                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontSize="10"
                                Foreground="#B0B0B0"
                                Text="{Binding StatusMessage}"
                                TextTrimming="CharacterEllipsis" />

                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <TextBlock Text="Exposures:" Foreground="#808080" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="#569CD6"
                                    Text="{Binding SessionExposuresTaken}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Expander Header="Status Log" IsExpanded="False" Margin="0,0,0,5" Foreground="#C0C0C0" FontSize="11">
                        <Border Background="#1A1A1A" CornerRadius="3" Padding="5" MaxHeight="180">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding StatusLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="55" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10" Text="{Binding LevelIcon}" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="10" Foreground="#707070" Text="{Binding FormattedTime}" />
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="10" Text="{Binding Message}" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#B0B0B0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                    <Setter Property="Foreground" Value="#E74C3C" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                    <Setter Property="Foreground" Value="#F39C12" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Success">
                                                                    <Setter Property="Foreground" Value="#27AE60" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Expander>

                    <ninactrl:DetachingExpander IsExpanded="True" Margin="0,0,0,6">
                        <ninactrl:DetachingExpander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Target" Foreground="#E0E0E0" FontWeight="SemiBold" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    Foreground="#4EC9B0"
                                    Text="{Binding Target.TargetName}" />
                                <TextBlock Margin="8,0,0,0" Foreground="#707070" Text="{Binding Target.InputCoordinates.Coordinates.RAString}" />
                                <TextBlock Margin="8,0,0,0" Foreground="#707070" Text="{Binding Target.InputCoordinates.Coordinates.DecString}" />
                                <TextBlock Margin="8,0,0,0" Foreground="#D69D29" Text="{Binding CurrentPositionAngleDisplay}" />
                            </StackPanel>
                        </ninactrl:DetachingExpander.Header>
                        <Border Background="#161616" BorderBrush="#3C3C3C" BorderThickness="1" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="280" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,8" Foreground="#C0C0C0" Text="Project/Target" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Foreground="#E0E0E0" Text="{Binding ProjectTargetDisplay}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,8" Foreground="#C0C0C0" Text="Coordinates" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Foreground="#E0E0E0" Text="{Binding CoordinatesDisplay}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,10,8" Foreground="#C0C0C0" Text="Position Angle" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Foreground="#E0E0E0" Text="{Binding CurrentPositionAngleDisplay}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,10,8" Foreground="#C0C0C0" Text="Stop At" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Foreground="#E0E0E0" Text="{Binding StopAtDisplay}" />

                                <Border
                                    Grid.Row="0"
                                    Grid.RowSpan="4"
                                    Grid.Column="2"
                                    Margin="20,0,0,0"
                                    Background="#10161C"
                                    BorderBrush="#3C3C3C"
                                    BorderThickness="1"
                                    Padding="4">
                                    <controls:CurrentTargetAltitudeChart
                                        Height="160"
                                        TargetCoordinates="{Binding CurrentTargetCoordinates}"
                                        ObserverLatitude="{Binding ObserverLatitude}"
                                        ObserverLongitude="{Binding ObserverLongitude}"
                                        MinAltitude="{Binding MinAltitude}"
                                        AstronomicalDusk="{Binding AstronomicalDusk}"
                                        AstronomicalDawn="{Binding AstronomicalDawn}" />
                                </Border>
                            </Grid>
                        </Border>
                    </ninactrl:DetachingExpander>

                    <Border Background="#161616" BorderBrush="#3C3C3C" BorderThickness="1" Padding="8" Margin="0,0,0,6">
                        <DataGrid
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            ItemsSource="{Binding TargetProgressItems}"
                            MinHeight="120"
                            BorderThickness="0"
                            Background="#161616"
                            Foreground="#E0E0E0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="*" Header="Item" Binding="{Binding ItemName}" />
                                <DataGridTextColumn Width="120" Header="Filter" Binding="{Binding FilterName}" />
                                <DataGridTextColumn Width="120" Header="Start" Binding="{Binding StartDisplay}" />
                                <DataGridTextColumn Width="120" Header="End" Binding="{Binding EndDisplay}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <ninactrl:DetachingExpander IsExpanded="True" Margin="0,0,0,5">
                        <ninactrl:DetachingExpander.Header>
                            <TextBlock Text="Custom Event Containers" />
                        </ninactrl:DetachingExpander.Header>
                        <StackPanel Margin="0,12,0,0" Orientation="Vertical">
                            <TextBlock
                                Margin="0,0,0,6"
                                Foreground="#A0A0A0"
                                FontSize="10"
                                Text="Use these buckets for target-aware instructions and plugin steps around AstroManager target changes. Triggers normally should not be added here. If you are unsure, please check the docs at docs.astro.sleeman.at." />

                            <ninactrl:DetachingExpander>
                                <ninactrl:DetachingExpander.Header>
                                    <TextBlock Text="Triggers" />
                                </ninactrl:DetachingExpander.Header>
                                <Border
                                    MinHeight="50"
                                    Margin="0,10,0,0"
                                    BorderBrush="#3C3C3C"
                                    BorderThickness="1">
                                    <Grid Background="#1A1A1A">
                                        <ItemsControl MinHeight="50" ItemsSource="{Binding Triggers}" />
                                        <TextBlock
                                            Height="18"
                                            MaxHeight="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            FontStyle="Italic"
                                            Foreground="#707070"
                                            Opacity="0.85"
                                            Text="Normally leave this empty. If unsure, check docs.astro.sleeman.at.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Triggers.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <i:Interaction.Behaviors>
                                            <behaviors:DragOverBehavior DragAboveSize="0" DragBelowSize="0" />
                                            <behaviors:DropIntoBehavior AllowedDragDropTypesString="NINA.Sequencer.Trigger.ISequenceTrigger" OnDropCommand="DropIntoTriggersCommand" />
                                        </i:Interaction.Behaviors>
                                    </Grid>
                                </Border>
                            </ninactrl:DetachingExpander>

                            <ninactrl:DetachingExpander>
                                <ninactrl:DetachingExpander.Header>
                                    <TextBlock Text="Before Wait Instructions" />
                                </ninactrl:DetachingExpander.Header>
                                <ContentControl
                                    Content="{Binding BeforeWaitContainer}"
                                    ContentTemplate="{StaticResource AstroManagerSchedulerEventContainerTemplate}"
                                    Tag="Drop instructions here to run before each AstroManager wait period" />
                            </ninactrl:DetachingExpander>

                            <ninactrl:DetachingExpander>
                                <ninactrl:DetachingExpander.Header>
                                    <TextBlock Text="After Wait Instructions" />
                                </ninactrl:DetachingExpander.Header>
                                <ContentControl
                                    Content="{Binding AfterWaitContainer}"
                                    ContentTemplate="{StaticResource AstroManagerSchedulerEventContainerTemplate}"
                                    Tag="Drop instructions here to run after each AstroManager wait period" />
                            </ninactrl:DetachingExpander>

                            <ninactrl:DetachingExpander>
                                <ninactrl:DetachingExpander.Header>
                                    <TextBlock Text="Before New Target Instructions" />
                                </ninactrl:DetachingExpander.Header>
                                <ContentControl
                                    Content="{Binding BeforeTargetContainer}"
                                    ContentTemplate="{StaticResource AstroManagerSchedulerEventContainerTemplate}"
                                    Tag="Drop instructions here to run before a new or changed target begins imaging" />
                            </ninactrl:DetachingExpander>

                            <ninactrl:DetachingExpander>
                                <ninactrl:DetachingExpander.Header>
                                    <TextBlock Text="After Each Exposure Instructions" />
                                </ninactrl:DetachingExpander.Header>
                                <ContentControl
                                    Content="{Binding AfterEachExposureContainer}"
                                    ContentTemplate="{StaticResource AstroManagerSchedulerEventContainerTemplate}"
                                    Tag="Drop instructions here to run after every completed exposure slot" />
                            </ninactrl:DetachingExpander>

                            <ninactrl:DetachingExpander>
                                <ninactrl:DetachingExpander.Header>
                                    <TextBlock Text="After New Target Instructions" />
                                </ninactrl:DetachingExpander.Header>
                                <ContentControl
                                    Content="{Binding AfterTargetContainer}"
                                    ContentTemplate="{StaticResource AstroManagerSchedulerEventContainerTemplate}"
                                    Tag="Drop instructions here to run after the current target segment finishes" />
                            </ninactrl:DetachingExpander>

                            <ninactrl:DetachingExpander>
                                <ninactrl:DetachingExpander.Header>
                                    <TextBlock Text="After Each Target Instructions" />
                                </ninactrl:DetachingExpander.Header>
                                <ContentControl
                                    Content="{Binding AfterEachTargetContainer}"
                                    ContentTemplate="{StaticResource AstroManagerSchedulerEventContainerTemplate}"
                                    Tag="Drop instructions here to run after each completed AstroManager target segment" />
                            </ninactrl:DetachingExpander>

                            <ninactrl:DetachingExpander>
                                <ninactrl:DetachingExpander.Header>
                                    <TextBlock Text="After Target Complete Instructions" />
                                </ninactrl:DetachingExpander.Header>
                                <ContentControl
                                    Content="{Binding AfterTargetCompleteContainer}"
                                    ContentTemplate="{StaticResource AstroManagerSchedulerEventContainerTemplate}"
                                    Tag="Drop instructions here to run once when AstroManager marks the target fully complete" />
                            </ninactrl:DetachingExpander>
                        </StackPanel>
                    </ninactrl:DetachingExpander>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:AstroManagerSchedulerContainer}">
        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource AstroManagerSchedulerContainerDetailTemplate}" />
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:AstroManagerTargetScheduler}">
        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource AstroManagerLegacySchedulerDetailTemplate}" />
    </DataTemplate>

    <DataTemplate x:Key="AstroManager.NinaPlugin.AstroManagerSchedulerContainer_Mini">
        <mini:MiniContainer>
            <mini:MiniContainer.Content>
                <StackPanel Orientation="Vertical">
                    <Grid Background="#1A1A1A" DataContext="{Binding BeforeWaitContainer}">
                        <ItemsControl MinHeight="35" ItemsSource="{Binding Items}" />
                    </Grid>
                    <Grid Background="#1A1A1A" DataContext="{Binding AfterWaitContainer}">
                        <ItemsControl MinHeight="35" ItemsSource="{Binding Items}" />
                    </Grid>
                    <Grid Background="#1A1A1A" DataContext="{Binding BeforeTargetContainer}">
                        <ItemsControl MinHeight="35" ItemsSource="{Binding Items}" />
                    </Grid>
                    <Grid Background="#1A1A1A" DataContext="{Binding AfterTargetContainer}">
                        <ItemsControl MinHeight="35" ItemsSource="{Binding Items}" />
                    </Grid>
                    <Grid Background="#1A1A1A" DataContext="{Binding AfterTargetCompleteContainer}">
                        <ItemsControl MinHeight="35" ItemsSource="{Binding Items}" />
                    </Grid>
                </StackPanel>
            </mini:MiniContainer.Content>
        </mini:MiniContainer>
    </DataTemplate>

    <DataTemplate x:Key="AstroManager.NinaPlugin.AstroManagerTargetScheduler_Mini">
        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
            <TextBlock Text="Legacy" Foreground="#D69D29" FontSize="11" VerticalAlignment="Center" />
            <TextBlock Margin="8,0,0,0" Text="Config:" Foreground="#909090" FontSize="11" VerticalAlignment="Center" />
            <TextBlock
                Margin="4,0,8,0"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#569CD6"
                Text="{Binding SelectedConfigurationName}" />
            <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11" Foreground="#505050" Text="|" />
            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#4EC9B0" Text="{Binding CurrentTargetName}" />
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
