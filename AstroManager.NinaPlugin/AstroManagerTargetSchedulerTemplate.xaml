<ResourceDictionary
    x:Class="AstroManager.NinaPlugin.AstroManagerTargetSchedulerTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:AstroManager.NinaPlugin"
    xmlns:nina="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer"
    xmlns:ninactrl="clr-namespace:NINA.CustomControlLibrary;assembly=NINA.CustomControlLibrary"
    xmlns:behaviors="clr-namespace:NINA.Sequencer.Behaviors;assembly=NINA.Sequencer">

    <!-- Detail template using NINA's SequenceBlockView wrapper (provides standard NINA controls) -->
    <DataTemplate DataType="{x:Type local:AstroManagerTargetScheduler}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                    <!-- Configuration Selection Row -->
                    <Border Background="#252526" CornerRadius="3" Padding="10,8" Margin="0,5,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Config Override:" 
                                       Foreground="#C0C0C0" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"
                                       ToolTip="Leave as 'Use Server Default' to use the default configuration set in AstroManager web UI"/>
                            
                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding AvailableConfigurations}"
                                      SelectedValue="{Binding SelectedConfigurationId, Mode=TwoWay}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Background="#3C3C3C" Foreground="#E0E0E0"
                                      FontSize="12" MinWidth="200"
                                      VerticalAlignment="Center"/>
                            
                            <Button Grid.Column="2" Content="↻" 
                                    Command="{Binding RefreshConfigurationsCommand}"
                                    ToolTip="Refresh configurations from server"
                                    Background="#3C3C3C" Foreground="#E0E0E0"
                                    FontSize="12" Padding="8,4" Margin="8,0,0,0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <!-- Status Row -->
                    <Border Background="#1E1E1E" CornerRadius="3" Padding="10,6" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Target:" Foreground="#808080" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentTargetName}" Foreground="#4EC9B0" FontSize="10" FontWeight="SemiBold" 
                                           VerticalAlignment="Center" Margin="4,0,12,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                                <TextBlock Text="PA:" Foreground="#808080" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentPositionAngleDisplay}" Foreground="#D69D29" FontSize="10" FontWeight="SemiBold" 
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" Foreground="#B0B0B0" FontSize="10" 
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <TextBlock Text="Exposures:" Foreground="#808080" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SessionExposuresTaken}" Foreground="#569CD6" FontSize="10" FontWeight="SemiBold" 
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Expandable Status Log -->
                    <Expander Header="Status Log" IsExpanded="False" Margin="0,0,0,5"
                              Foreground="#C0C0C0" FontSize="11">
                        <Border Background="#1A1A1A" CornerRadius="3" Padding="5" MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding StatusLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="55"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding LevelIcon}" FontSize="10" 
                                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FormattedTime}" 
                                                           Foreground="#707070" FontSize="10" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Message}" 
                                                           FontSize="10" TextWrapping="Wrap" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#B0B0B0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                    <Setter Property="Foreground" Value="#F39C12"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Success">
                                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Expander>
                    
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>
    
    <!-- Mini template for collapsed/summary view in sequence list -->
    <DataTemplate x:Key="AstroManager.NinaPlugin.AstroManagerTargetScheduler_Mini">
        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
            <TextBlock Text="Config:" Foreground="#909090" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedConfigurationName}" Foreground="#569CD6" FontSize="11" 
                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,8,0"/>
            <TextBlock Text="|" Foreground="#505050" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding CurrentTargetName}" Foreground="#4EC9B0" FontSize="11" 
                       VerticalAlignment="Center"/>
            <TextBlock Text=" PA:" Foreground="#707070" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <TextBlock Text="{Binding CurrentPositionAngleDisplay}" Foreground="#D69D29" FontSize="11" 
                       VerticalAlignment="Center" Margin="2,0,0,0"/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
