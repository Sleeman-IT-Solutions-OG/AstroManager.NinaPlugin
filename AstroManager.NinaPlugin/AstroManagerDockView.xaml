<ResourceDictionary
    x:Class="AstroManager.NinaPlugin.AstroManagerDockView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AstroManager.NinaPlugin"
    xmlns:controls="clr-namespace:AstroManager.NinaPlugin.Controls">

    <!-- Expander Style with visible toggle button -->
    <Style x:Key="GroupExpanderStyle" TargetType="Expander">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <StackPanel>
                            <!-- Header with toggle button -->
                            <ToggleButton x:Name="HeaderToggle" 
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" 
                                          BorderThickness="0"
                                          Cursor="Hand"
                                          Padding="4">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Expand/Collapse Arrow -->
                                                <TextBlock x:Name="Arrow" 
                                                           Text="▶" 
                                                           FontSize="10" 
                                                           Foreground="{DynamicResource SecondaryBrush}"
                                                           VerticalAlignment="Center" 
                                                           Margin="0,0,6,0"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="ArrowRotate" Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <!-- Header Content -->
                                                <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Arrow" Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <!-- Content Area -->
                            <ContentPresenter x:Name="Content" 
                                              Visibility="Collapsed"
                                              Margin="4,0,4,4"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="Content" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataTemplate key must be: <FullyQualifiedTypeName>_Dockable -->
    <DataTemplate x:Key="AstroManager.NinaPlugin.AstroManagerDockVM_Dockable">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="5">
                
                <!-- Header with Connection Status -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="AstroManager" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="Target Status" Foreground="{DynamicResource SecondaryBrush}" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource SecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource NotificationSuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="{DynamicResource SecondaryBrush}" FontSize="10"/>
                    </StackPanel>
                </Grid>

                <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SAFETY POLICY" Foreground="{DynamicResource SecondaryBrush}" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding RuntimeSafetyPolicyName}" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

                <!-- Current Target Section -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="CURRENT TARGET" Foreground="{DynamicResource SecondaryBrush}" FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        
                        <!-- No Target State -->
                        <TextBlock Text="No active target" Foreground="{DynamicResource SecondaryBrush}" FontSize="11"
                                   Visibility="{Binding HasCurrentTarget, Converter={StaticResource InverseBooleanToVisibilityCollapsedConverter}}"/>
                        
                        <!-- Target Info -->
                        <StackPanel Visibility="{Binding HasCurrentTarget, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding CurrentTargetName}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Foreground="{DynamicResource SecondaryBrush}" FontSize="10" VerticalAlignment="Center">
                                    <Run Text="P"/>
                                    <Run Text="{Binding CurrentTargetPriority, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                            <TextBlock Text="{Binding CurrentTargetType}" Foreground="{DynamicResource SecondaryBrush}" FontSize="10" Margin="0,2,0,0"/>
                            
                            <!-- Progress Bar -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="{Binding CurrentTargetProgress}" Maximum="100" Height="6" 
                                             Background="{DynamicResource TertiaryBackgroundBrush}" Foreground="{DynamicResource ButtonBackgroundBrush}"/>
                                <TextBlock Grid.Column="1" Foreground="{DynamicResource PrimaryBrush}" FontSize="10" Margin="5,0,0,0">
                                    <Run Text="{Binding CurrentTargetProgress, StringFormat='{}{0:F0}', Mode=OneWay}"/>
                                    <Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            
                            <!-- Imaging Goals -->
                            <TextBlock Text="IMAGING GOALS" Foreground="{DynamicResource SecondaryBrush}" FontSize="9" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ItemsControl ItemsSource="{Binding CurrentTargetGoals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="45"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding FilterName}" Foreground="{DynamicResource ButtonBackgroundBrush}" FontSize="10" FontWeight="SemiBold"/>
                                            <ProgressBar Grid.Column="1" Value="{Binding CompletedExposures}" Maximum="{Binding PlannedExposures}" 
                                                         Height="4" Margin="5,0" Background="{DynamicResource TertiaryBackgroundBrush}" Foreground="{DynamicResource ButtonBackgroundBrush}"/>
                                            <TextBlock Grid.Column="2" Foreground="{DynamicResource PrimaryBrush}" FontSize="9" HorizontalAlignment="Right">
                                                <Run Text="{Binding CompletedExposures, Mode=OneWay}"/>
                                                <Run Text="/"/>
                                                <Run Text="{Binding PlannedExposures, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Altitude Chart for Current Target -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,0,8"
                        Visibility="{Binding HasCurrentTarget, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                    <StackPanel>
                        <TextBlock Text="ALTITUDE CHART" Foreground="{DynamicResource SecondaryBrush}" FontSize="9" FontWeight="SemiBold" Margin="4,0,0,4"/>
                        <controls:CurrentTargetAltitudeChart 
                            Height="150"
                            TargetCoordinates="{Binding CurrentTargetCoordinates}"
                            ObserverLatitude="{Binding ObserverLatitude}"
                            ObserverLongitude="{Binding ObserverLongitude}"
                            MinAltitude="{Binding MinAltitude}"
                            AstronomicalDusk="{Binding AstronomicalDusk}"
                            AstronomicalDawn="{Binding AstronomicalDawn}"/>
                    </StackPanel>
                </Border>

                <!-- Scheduler Status Log Section -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SCHEDULER LOG" Foreground="{DynamicResource SecondaryBrush}" FontSize="9" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding SchedulerStatus}" Foreground="{DynamicResource ButtonBackgroundBrush}" FontSize="9"/>
                        </Grid>
                        
                        <Border Background="{DynamicResource TertiaryBackgroundBrush}" CornerRadius="3" Padding="4" MaxHeight="150">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SchedulerLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding LevelIcon}" FontSize="9" 
                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FormattedTime}" 
                                                           Foreground="{DynamicResource SecondaryBrush}" FontSize="9" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Message}" 
                                                           Foreground="{DynamicResource PrimaryBrush}" FontSize="9" 
                                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Action Button -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="🔄 Sync &amp; Refresh" Command="{Binding SyncCommand}" Padding="12,4"/>
                </StackPanel>
                
                <!-- Last Sync Time -->
                <TextBlock HorizontalAlignment="Center" Margin="0,5,0,0" Foreground="{DynamicResource SecondaryBrush}" FontSize="9">
                    <Run Text="Last sync: "/>
                    <Run Text="{Binding LastSyncTime, Mode=OneWay}"/>
                </TextBlock>
                
            </StackPanel>
        </ScrollViewer>
    </DataTemplate>
    
</ResourceDictionary>
