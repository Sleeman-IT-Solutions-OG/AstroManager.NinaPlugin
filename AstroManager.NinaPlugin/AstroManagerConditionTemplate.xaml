<ResourceDictionary
    x:Class="AstroManager.NinaPlugin.AstroManagerConditionTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AstroManager.NinaPlugin">

    <!-- DataTemplate for AstroManagerLoopCondition -->
    <DataTemplate DataType="{x:Type local:AstroManagerLoopCondition}">
        <Grid Margin="5,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding ConditionTypes}"
                      SelectedItem="{Binding SelectedCondition, Mode=TwoWay}"
                      MinWidth="180"
                      Background="#3C3C3C" 
                      Foreground="#E0E0E0"
                      FontSize="12"
                      VerticalAlignment="Center">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="WhileActive">
                                            <Setter Property="Text" Value="Until no more targets available"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- Remove/Delete Button -->
            <Button Grid.Column="1" 
                    Command="{Binding DetachCommand}"
                    ToolTip="Remove condition"
                    Margin="5,0,0,0"
                    Padding="4,2"
                    Background="Transparent"
                    BorderBrush="#666666"
                    Foreground="#E0E0E0"
                    VerticalAlignment="Center"
                    Cursor="Hand">
                <TextBlock Text="✕" FontSize="10" FontWeight="Bold"/>
            </Button>
        </Grid>
    </DataTemplate>

    <!-- Mini template for collapsed view -->
    <DataTemplate x:Key="AstroManager.NinaPlugin.AstroManagerLoopCondition_Mini">
        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
            <TextBlock Text="{Binding ConditionDescription}" 
                       Foreground="#4EC9B0" 
                       FontSize="11" 
                       VerticalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
