                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Min Seq (min)" Style="{StaticResource FieldLabel}" ToolTip="Minimum sequence duration in minutes. Target won't be scheduled if available time is less than this. Helps avoid very short imaging windows."/>
