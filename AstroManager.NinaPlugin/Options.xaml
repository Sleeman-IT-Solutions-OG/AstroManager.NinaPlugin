                                                        <CheckBox IsChecked="{Binding SelectedSchedulerConfiguration.AlwaysStopWhenNoTargetsForNight, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Stop if no targets for night" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
