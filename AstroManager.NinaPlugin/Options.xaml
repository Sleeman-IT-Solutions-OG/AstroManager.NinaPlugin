                                                        <CheckBox IsChecked="{Binding SelectedSchedulerConfiguration.EnableMountAltitudeCheck, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Mount altitude guard" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
