<ResourceDictionary
    x:Class="AstroManager.NinaPlugin.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AstroManager.NinaPlugin"
    xmlns:controls="clr-namespace:AstroManager.NinaPlugin.Controls">

    <!-- Converters -->
    <local:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
    <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
    <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <local:ZeroToVisibilityConverter x:Key="ZeroToVisConverter"/>
    <local:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
    <local:GoalCompletionBehaviorDisplayConverter x:Key="GoalCompletionDisplayConverter"/>
    <local:FilterShootingPatternDisplayConverter x:Key="FilterPatternDisplayConverter"/>
    <local:StrategyDisplayConverter x:Key="StrategyDisplayConverter"/>
    <local:MultiBoolToVisibilityConverter x:Key="MultiBoolToVisConverter"/>
    <local:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisConverter"/>

    <!-- Styles -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="BorderBrush" Value="#3C3C3C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    
    <Style x:Key="SubSectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#B0B0B0"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    
    <Style x:Key="SectionDivider" TargetType="Border">
        <Setter Property="BorderBrush" Value="#3C3C3C"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Margin" Value="0,12,0,12"/>
        <Setter Property="Padding" Value="0,0,0,8"/>
    </Style>
    
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#C0C0C0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
    
    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="#D0D0D0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    
    <Style x:Key="ValueText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    
    <Style x:Key="InputBox" TargetType="TextBox">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="BorderBrush" Value="#3C3C3C"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="28"/>
    </Style>
    
    <Style x:Key="ActionButton" TargetType="Button">
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Background" Value="#0E639C"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="30"/>
    </Style>
    
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Background" Value="#3C3C3C"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="30"/>
    </Style>
    
    <Style x:Key="SmallButton" TargetType="Button">
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Background" Value="#3C3C3C"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="MinHeight" Value="20"/>
        <Setter Property="MinWidth" Value="20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#505050"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#606060"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    
    <Style x:Key="ExpanderStyle" TargetType="Expander">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#3C3C3C"/>
        <Setter Property="IsExpanded" Value="False"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    
    <!-- Expander style with visible toggle arrow for target groups -->
    <Style x:Key="TargetGroupExpanderStyle" TargetType="Expander">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="BorderBrush" Value="#5A7FBA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border x:Name="MainBorder" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="2">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderToggle" 
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" 
                                          BorderThickness="0"
                                          Cursor="Hand"
                                          HorizontalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" Padding="4,4,4,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="Arrow" 
                                                           Text="▶" 
                                                           FontSize="10" 
                                                           Foreground="#B0B0B0"
                                                           VerticalAlignment="Center" 
                                                           Margin="0,0,6,0"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}" HorizontalAlignment="Stretch"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Arrow" Property="Foreground" Value="#569CD6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <ContentPresenter x:Name="Content" 
                                              Visibility="Collapsed"
                                              Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="Content" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#7BA3D8"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#8AB8E8"/>
                            <Setter TargetName="MainBorder" Property="Background" Value="#353540"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The DataTemplate key must match: "<AssemblyTitle>_Options" -->
    <DataTemplate x:Key="AstroManager_Options">
        <Grid>
            <!-- Main Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="10" HorizontalAlignment="Stretch">
                
                    <!-- Header -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- AstroManager Logo - Telescope + Star (matching AM App) -->
                        <Grid Width="32" Height="32" Margin="0,0,10,0">
                            <!-- 5-point star at top right -->
                            <Path Fill="#4EC9B0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0"
                                  Data="M8,0 L9.5,5 L15,5 L10.5,8 L12,14 L8,10.5 L4,14 L5.5,8 L1,5 L6.5,5 Z"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
                                </Path.RenderTransform>
                            </Path>
                            <!-- Telescope body (angled rectangle) -->
                            <Path Fill="#4EC9B0" Data="M4,14 L14,8 L15,10 L5,16 Z" Margin="2,8,0,0"/>
                            <!-- Mount circle -->
                            <Ellipse Fill="#4EC9B0" Width="5" Height="5" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                            <!-- Tripod legs -->
                            <Path Stroke="#4EC9B0" StrokeThickness="1.5" Data="M10,24 L6,32 M12,24 L16,32" Margin="0,0,0,0"/>
                        </Grid>
                        <StackPanel>
                            <TextBlock Text="AstroManager" FontSize="18" FontWeight="Bold" Foreground="#E0E0E0"/>
                            <TextBlock Text="Sync your imaging targets" Foreground="#C0C0C0" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Error Status Badge -->
                    <Border Grid.Column="1" Background="#B03030" CornerRadius="4" Padding="8,4" VerticalAlignment="Center" Margin="0,0,10,0"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" FontSize="11" VerticalAlignment="Center" MaxWidth="200" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding ErrorMessage}"/>
                        </StackPanel>
                    </Border>
                    <!-- Connection Status Badge -->
                    <Border Grid.Column="2" Background="{Binding ConnectionStatusColor}" CornerRadius="4" Padding="10,5" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                    </Border>
                </Grid>

                <!-- Row 1: Connection & Status (Collapsible) -->
                <Expander Style="{StaticResource ExpanderStyle}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#0E639C"/>
                            <TextBlock Text="Connection &amp; Status" FontSize="13" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                        </StackPanel>
                    </Expander.Header>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Connection Card -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Connection" Style="{StaticResource SubSectionHeader}"/>
                                
                                <TextBlock Text="License Key" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Margin="0,0,0,8"
                                         Text="{Binding LicenseKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Your AstroManager license key. Get this from your AstroManager account settings."/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button Content="Test Connection" Command="{Binding TestConnectionCommand}" Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                                    <Button Content="Sync Targets" Command="{Binding SyncTargetsCommand}" Style="{StaticResource SecondaryButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Status Card -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Status" Style="{StaticResource SubSectionHeader}"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Text="CACHED TARGETS" Foreground="#909090" FontSize="9" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CachedTargetCount}" FontSize="20" FontWeight="Bold" Foreground="#4EC9B0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="LAST SYNC" Foreground="#909090" FontSize="9" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LastSyncTime}" FontSize="12" Foreground="#E0E0E0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Text="HEARTBEAT" Foreground="#909090" FontSize="9" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding HeartbeatStatus}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding HeartbeatStatusColor}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="LAST ACTIVITY" Foreground="#909090" FontSize="9" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LastHeartbeatTime}" FontSize="12" Foreground="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Button Content="Start" Command="{Binding StartHeartbeatCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,5,0"/>
                                    <Button Content="Stop" Command="{Binding StopHeartbeatCommand}" Style="{StaticResource SecondaryButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Expander>

                <!-- Row 2: AstroManager Data (Collapsible) -->
                <Expander Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#C586C0"/>
                            <TextBlock Text="AstroManager Data" FontSize="13" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0" MinHeight="350">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Left Panel: Data Type Selection as styled buttons -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DATA TYPE" Foreground="#909090" FontSize="9" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Button Command="{Binding SelectExposureTemplatesCommand}" 
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" Padding="8,6" HorizontalContentAlignment="Left">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Exp. Templates" FontSize="12"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Background>
                                        <Binding Path="IsExposureTemplatesSelected">
                                            <Binding.Converter>
                                                <local:BoolToColorConverter TrueColor="#0E639C" FalseColor="#3C3C3C"/>
                                            </Binding.Converter>
                                        </Binding>
                                    </Button.Background>
                                </Button>
                                <Button Command="{Binding SelectSchedulerConfigCommand}" 
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" Padding="8,6" HorizontalContentAlignment="Left">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Scheduler Config" FontSize="12"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Background>
                                        <Binding Path="IsSchedulerConfigSelected">
                                            <Binding.Converter>
                                                <local:BoolToColorConverter TrueColor="#0E639C" FalseColor="#3C3C3C"/>
                                            </Binding.Converter>
                                        </Binding>
                                    </Button.Background>
                                </Button>
                                <Button Command="{Binding SelectSchedulerTargetTemplatesCommand}" 
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" Padding="8,6" HorizontalContentAlignment="Left">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Target Templates" FontSize="12"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Background>
                                        <Binding Path="IsSchedulerTargetTemplatesSelected">
                                            <Binding.Converter>
                                                <local:BoolToColorConverter TrueColor="#0E639C" FalseColor="#3C3C3C"/>
                                            </Binding.Converter>
                                        </Binding>
                                    </Button.Background>
                                </Button>
                                <Button Command="{Binding SelectMoonAvoidanceCommand}" 
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" Padding="8,6" HorizontalContentAlignment="Left">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEC46;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Moon Avoidance" FontSize="12"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Background>
                                        <Binding Path="IsMoonAvoidanceSelected">
                                            <Binding.Converter>
                                                <local:BoolToColorConverter TrueColor="#0E639C" FalseColor="#3C3C3C"/>
                                            </Binding.Converter>
                                        </Binding>
                                    </Button.Background>
                                </Button>
                                <Button Command="{Binding SelectObservatoryCommand}" 
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,4" Padding="8,6" HorizontalContentAlignment="Left">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Observatory" FontSize="12"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Background>
                                        <Binding Path="IsObservatorySelected">
                                            <Binding.Converter>
                                                <local:BoolToColorConverter TrueColor="#0E639C" FalseColor="#3C3C3C"/>
                                            </Binding.Converter>
                                        </Binding>
                                    </Button.Background>
                                </Button>
                                
                                <Button Content="Load from API" Command="{Binding LoadSettingsFromApiCommand}" 
                                        Style="{StaticResource SecondaryButton}" Margin="0,10,0,0" FontSize="10"
                                        ToolTip="Refresh data from AstroManager"/>
                            </StackPanel>
                            
                            <!-- Right Panel: Content based on selection -->
                            <Border Grid.Column="2" Background="#252526" CornerRadius="4" Padding="10">
                                <StackPanel>
                                    <!-- Exposure Templates Content -->
                                    <StackPanel Visibility="{Binding IsExposureTemplatesSelected, Converter={StaticResource BoolToVisConverter}}">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="EXPOSURE TEMPLATES" Foreground="#569CD6" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ExposureTemplateCount, StringFormat=' ({0})'}" 
                                                           Foreground="#4EC9B0" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="+ Add" Command="{Binding AddExposureTemplateCommand}" 
                                                    Style="{StaticResource ActionButton}" Padding="12,5" FontSize="12"/>
                                        </Grid>
                                        
                                        <!-- Filter Mismatch Warning -->
                                        <Border Background="#5C3A00" CornerRadius="3" Padding="8" Margin="0,0,0,8"
                                                Visibility="{Binding HasFilterMismatch, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="{Binding FilterMismatchWarning}" Foreground="#FFB74D" FontSize="12" TextWrapping="Wrap"/>
                                        </Border>
                                        
                                        <!-- Grid Header Row -->
                                        <Border Background="#1E1E1E" CornerRadius="3,3,0,0" Padding="6,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="62"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="38"/>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="32"/>
                                                    <ColumnDefinition Width="32"/>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="32"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="Name" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Template name - used to identify this exposure setup"/>
                                                <TextBlock Grid.Column="2" Text="#" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Filter Priority (1=highest). Determines capture order when using priority-based filter patterns."/>
                                                <TextBlock Grid.Column="3" Text="Filter" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Filter name (must match your filter wheel)"/>
                                                <TextBlock Grid.Column="4" Text="Exp" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Exposure time in seconds"/>
                                                <TextBlock Grid.Column="5" Text="Gain" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Camera gain setting (-1 = use camera default)"/>
                                                <TextBlock Grid.Column="6" Text="Offs" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Camera offset setting (-1 = use camera default)"/>
                                                <TextBlock Grid.Column="7" Text="Bin" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Binning (1=1x1, 2=2x2, etc.)"/>
                                                <TextBlock Grid.Column="8" Text="RO" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Readout Mode (camera-specific)"/>
                                                <TextBlock Grid.Column="9" Text="Dith" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Dither after every X exposures (-1 = use NINA default)"/>
                                                <TextBlock Grid.Column="10" Text="Alt" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Minimum altitude for this filter. Use narrowband at lower altitudes, RGB higher."/>
                                                <TextBlock Grid.Column="11" Text="Twilight" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Minimum darkness level: Night, Astronomical, Nautical, Civil"/>
                                                <TextBlock Grid.Column="12" Text="Moon" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Moon avoidance profile - stricter for broadband, relaxed for narrowband"/>
                                            </Grid>
                                        </Border>
                                        
                                        <ListBox ItemsSource="{Binding ExposureTemplates}" 
                                                 SelectedItem="{Binding SelectedExposureTemplate, Mode=TwoWay}"
                                                 Background="#2D2D30" BorderBrush="#4A4A4A" MaxHeight="250" Margin="0,0,0,8">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#3C3C3C" BorderBrush="#4A4A4A" BorderThickness="0,0,0,1" Padding="6,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="62"/>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="22"/>
                                                                <ColumnDefinition Width="38"/>
                                                                <ColumnDefinition Width="36"/>
                                                                <ColumnDefinition Width="32"/>
                                                                <ColumnDefinition Width="32"/>
                                                                <ColumnDefinition Width="22"/>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="32"/>
                                                                <ColumnDefinition Width="70"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Command="{Binding DataContext.CopyExposureTemplateCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                                        CommandParameter="{Binding}" Background="#505050" Foreground="#E0E0E0" BorderThickness="0" 
                                                                        Padding="8,5" Margin="0,0,4,0" Cursor="Hand" ToolTip="Copy template">
                                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.DeleteExposureTemplateCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                                        CommandParameter="{Binding}" Background="#6B3030" Foreground="#E0E0E0" BorderThickness="0" 
                                                                        Padding="8,5" Cursor="Hand" ToolTip="Delete template">
                                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                                </Button>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name, Mode=OneWay}" Foreground="#FFFFFF" FontSize="12" 
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding DefaultFilterPriority, Mode=OneWay}" Foreground="#4EC9B0" FontSize="10" 
                                                                       VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Border Background="#0E639C" CornerRadius="2" Padding="3,1" HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding Filter, Mode=OneWay}" Foreground="White" FontSize="9" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <!-- Filter Warning Icon -->
                                                                <TextBlock Text="⚠" Foreground="#FFB900" FontSize="10" Margin="2,0,0,0" VerticalAlignment="Center"
                                                                           Visibility="{Binding IsFilterMismatch, Converter={StaticResource BoolToVisConverter}}"
                                                                           ToolTip="Filter not available in connected NINA filter wheel"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="4" Foreground="#E0E0E0" FontSize="10" VerticalAlignment="Center">
                                                                <Run Text="{Binding ExposureTimeSeconds, Mode=OneWay}"/><Run Text="s"/>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="5" Text="{Binding Gain, Mode=OneWay}" Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="6" Text="{Binding Offset, Mode=OneWay}" Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="7" Text="{Binding Binning, Mode=OneWay}" Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="8" Text="{Binding ReadoutMode, Mode=OneWay, TargetNullValue='-'}" Foreground="#C0C0C0" FontSize="9" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="9" Text="{Binding DitherEveryX, Mode=OneWay, TargetNullValue='-'}" Foreground="#C0C0C0" FontSize="9" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="10" Text="{Binding MinAltitude, Mode=OneWay, StringFormat={}{0:F0}°}" Foreground="#C0C0C0" FontSize="9" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="11" Text="{Binding AcceptableTwilight, Mode=OneWay}" Foreground="#C0C0C0" FontSize="9" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="12" Text="{Binding MoonAvoidanceProfileName, Mode=OneWay, TargetNullValue='-'}" Foreground="#C0C0C0" FontSize="9" 
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding MoonAvoidanceProfileName}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        
                                        <!-- Selected Template Edit Panel (Compact) -->
                                        <Border Background="#2D2D30" CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                                                Visibility="{Binding HasSelectedExposureTemplate, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="✏️ EDIT TEMPLATE" Foreground="#D69D29" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="✕" Command="{Binding CloseExposureTemplateEditCommand}" 
                                                            Background="Transparent" Foreground="#909090" BorderThickness="0" 
                                                            Padding="4,1" FontSize="12" Cursor="Hand" ToolTip="Close"/>
                                                </Grid>
                                                <!-- Row 1: Name, Filter, Exp, Binning, Priority -->
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="55"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Name" Foreground="#C0C0C0" FontSize="10"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedExposureTemplate.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Filter" Foreground="#C0C0C0" FontSize="10"/>
                                                        <ComboBox ItemsSource="{Binding FilterValues}" SelectedItem="{Binding SelectedExposureTemplate.Filter, Mode=TwoWay}"
                                                                  Background="#3C3C3C" Foreground="#FFFFFF" FontSize="12" Padding="4,2" MinHeight="24"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Exp (s)" Foreground="#C0C0C0" FontSize="10"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedExposureTemplate.ExposureTimeSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="6">
                                                        <TextBlock Text="Bin" Foreground="#C0C0C0" FontSize="10"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedExposureTemplate.Binning, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="8">
                                                        <TextBlock Text="Prio" Foreground="#C0C0C0" FontSize="10" ToolTip="Priority (1=highest)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedExposureTemplate.DefaultFilterPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="12" ToolTip="1 = highest priority"/>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Row 2: Gain, Offset, Dither every X, Twilight, ReadoutMode -->
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Gain" Foreground="#C0C0C0" FontSize="10" ToolTip="-1 = camera default"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedExposureTemplate.Gain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Offset" Foreground="#C0C0C0" FontSize="10" ToolTip="-1 = camera default"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedExposureTemplate.Offset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Dither every X" Foreground="#C0C0C0" FontSize="10" ToolTip="Dither every X frames (-1 = NINA default)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedExposureTemplate.DitherEveryX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="6">
                                                        <TextBlock Text="Min Altitude" Foreground="#C0C0C0" FontSize="10" ToolTip="Minimum altitude in degrees (-1 = scheduler default)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedExposureTemplate.MinAltitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="8">
                                                        <TextBlock Text="Acceptable Twilight" Foreground="#C0C0C0" FontSize="10" ToolTip="Minimum twilight level for this filter"/>
                                                        <ComboBox ItemsSource="{Binding TwilightValues}" SelectedItem="{Binding SelectedExposureTemplate.AcceptableTwilight, Mode=TwoWay}"
                                                                  Background="#3C3C3C" Foreground="#FFFFFF" FontSize="12" Padding="4,2" MinHeight="24"/>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Row 3: Moon Avoidance + Buttons -->
                                                <Grid Margin="0,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Moon Avoidance" Foreground="#C0C0C0" FontSize="10"/>
                                                        <ComboBox ItemsSource="{Binding MoonAvoidanceProfiles}" 
                                                                  SelectedValue="{Binding SelectedExposureTemplateMoonAvoidanceProfileId, Mode=TwoWay}"
                                                                  SelectedValuePath="Id" DisplayMemberPath="Name"
                                                                  Background="#3C3C3C" Foreground="#FFFFFF" FontSize="12" Padding="4,2" MinHeight="24"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                        <Button Content="💾 Save" Command="{Binding SaveExposureTemplateCommand}" Style="{StaticResource ActionButton}" Margin="0,0,6,0" Padding="10,4" FontSize="12"/>
                                                        <Button Content="Cancel" Command="{Binding CloseExposureTemplateEditCommand}" Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="12"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    
                                    <!-- Scheduler Config Content -->
                                    <StackPanel Visibility="{Binding IsSchedulerConfigSelected, Converter={StaticResource BoolToVisConverter}}">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="SCHEDULER CONFIGURATIONS" Foreground="#569CD6" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding SchedulerConfigCount, StringFormat=' ({0})'}" Foreground="#4EC9B0" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="+ Add" Command="{Binding AddSchedulerConfigCommand}" 
                                                    Style="{StaticResource ActionButton}" Padding="12,5" FontSize="12"/>
                                        </Grid>
                                        
                                        <!-- Grid Header Row -->
                                        <Border Background="#1E1E1E" CornerRadius="3,3,0,0" Padding="6,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="45"/>
                                                    <ColumnDefinition Width="75"/>
                                                    <ColumnDefinition Width="55"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="Name" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Configuration name"/>
                                                <TextBlock Grid.Column="2" Text="Alt≥" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Default minimum altitude for all targets"/>
                                                <TextBlock Grid.Column="3" Text="Strategy" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Primary target selection strategy"/>
                                                <TextBlock Grid.Column="4" Text="Pattern" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Filter shooting pattern"/>
                                                <TextBlock Grid.Column="5" Text="Goal" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" ToolTip="Behavior when imaging goals complete"/>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Scheduler Config List -->
                                        <ListBox ItemsSource="{Binding SchedulerConfigurations}" 
                                                 SelectedItem="{Binding SelectedSchedulerConfiguration, Mode=TwoWay}"
                                                 Background="#2D2D30" BorderBrush="#4A4A4A" MaxHeight="200" Margin="0,0,0,8">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#3C3C3C" BorderBrush="#4A4A4A" BorderThickness="0,0,0,1" Padding="6,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="140"/>
                                                                <ColumnDefinition Width="45"/>
                                                                <ColumnDefinition Width="75"/>
                                                                <ColumnDefinition Width="55"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Command="{Binding DataContext.SetDefaultSchedulerConfigCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                                        CommandParameter="{Binding}" Background="#3A6A3A" Foreground="#E0E0E0" BorderThickness="0" 
                                                                        Padding="8,5" Margin="0,0,4,0" Cursor="Hand" ToolTip="Set as default">
                                                                    <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.CopySchedulerConfigCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                                        CommandParameter="{Binding}" Background="#505050" Foreground="#E0E0E0" BorderThickness="0" 
                                                                        Padding="8,5" Margin="0,0,4,0" Cursor="Hand" ToolTip="Copy">
                                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.DeleteSchedulerConfigCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                                        CommandParameter="{Binding}" Background="#6B3030" Foreground="#E0E0E0" BorderThickness="0" 
                                                                        Padding="8,5" Cursor="Hand" ToolTip="Delete">
                                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                                </Button>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                                                <Border Background="#4EC9B0" CornerRadius="2" Padding="3,1" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                        Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisConverter}}">
                                                                    <TextBlock Text="DEF" Foreground="#1E1E1E" FontSize="9" FontWeight="SemiBold"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" Foreground="#909090" FontSize="12" VerticalAlignment="Center">
                                                                <Run Text="{Binding MinAltitudeDegrees, Mode=OneWay}"/><Run Text="°"/>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="3" Text="{Binding PrimaryStrategy, Mode=OneWay, Converter={StaticResource StrategyDisplayConverter}}" Foreground="#909090" FontSize="10" 
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding FilterShootingPattern, Mode=OneWay, Converter={StaticResource FilterPatternDisplayConverter}}" Foreground="#909090" FontSize="10" 
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="5" Text="{Binding GoalCompletionBehavior, Mode=OneWay, Converter={StaticResource GoalCompletionDisplayConverter}}" Foreground="#909090" FontSize="10" 
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        
                                        <!-- Selected Config Edit Panel -->
                                        <Border Background="#2D2D30" CornerRadius="4" Padding="12" Margin="0,0,0,8"
                                                Visibility="{Binding HasSelectedSchedulerConfiguration, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="✏️ EDIT CONFIGURATION" Foreground="#D69D29" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="✕" Command="{Binding CloseSchedulerConfigEditCommand}" 
                                                            Background="Transparent" Foreground="#909090" BorderThickness="0" 
                                                            Padding="6,2" FontSize="14" Cursor="Hand" ToolTip="Close"/>
                                                </Grid>
                                                <!-- Row 1: Name, Min Alt, Efficiency -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Name" Style="{StaticResource FieldLabel}" ToolTip="A descriptive name for this scheduler configuration"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Configuration name (e.g., 'Default', 'Deep Sky Priority', 'Wide Field')"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Min Alt (°)" Style="{StaticResource FieldLabel}" ToolTip="Default minimum altitude for all targets. Individual targets can override this."/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MinAltitudeDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Minimum altitude in degrees (e.g., 30). Targets below this won't be scheduled."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Efficiency (%)" Style="{StaticResource FieldLabel}" ToolTip="Account for slew time, focusing, etc. 80% means 20% overhead assumed."/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.ImagingEfficiencyPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Imaging efficiency 50-100% (e.g., 80 = 20% overhead for slews/focus)"/>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Row 2: Prioritization Mode -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Prioritization Mode" Style="{StaticResource FieldLabel}" ToolTip="Simple keeps the legacy primary/secondary/tertiary ordering. Weighted scores eligible targets across enabled metrics."/>
                                                        <ComboBox ItemsSource="{Binding PrioritizationModeDisplayValues}"
                                                                  SelectedValue="{Binding SelectedSchedulerPrioritizationMode, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" Background="#252526" CornerRadius="3" Padding="10,6">
                                                        <TextBlock Foreground="#A0A0A0" FontSize="10" TextWrapping="Wrap">
                                                            <Run Text="Simple:" FontWeight="SemiBold" Foreground="#C0C0C0"/>
                                                            <Run Text=" use Primary / Secondary / Tertiary tiebreakers. "/>
                                                            <Run Text="Weighted:" FontWeight="SemiBold" Foreground="#C0C0C0"/>
                                                            <Run Text=" set a weight per metric. Weight 0 disables that metric and thresholds scale linearly."/>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>

                                                <!-- Row 3: Strategy Selection -->
                                                <Grid Margin="0,0,0,6"
                                                      Visibility="{Binding IsSimplePrioritizationSelectedForConfig, Converter={StaticResource BoolToVisConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Primary Strategy" Style="{StaticResource FieldLabel}" ToolTip="How targets are ranked and selected. Priority=by priority number, Altitude=highest first, Completion=highest complete first"/>
                                                        <ComboBox ItemsSource="{Binding TargetSelectionStrategyDisplayValues}" 
                                                                  SelectedValue="{Binding SelectedSchedulerConfiguration.PrimaryStrategy, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Secondary Strategy" Style="{StaticResource FieldLabel}" ToolTip="Used when multiple targets tie on primary strategy"/>
                                                        <ComboBox ItemsSource="{Binding TargetSelectionStrategyDisplayValuesWithNull}" 
                                                                  SelectedValue="{Binding SelectedSchedulerConfiguration.SecondaryStrategy, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Tertiary Strategy" Style="{StaticResource FieldLabel}" ToolTip="Third-level tiebreaker if primary and secondary are equal"/>
                                                        <ComboBox ItemsSource="{Binding TargetSelectionStrategyDisplayValuesWithNull}" 
                                                                  SelectedValue="{Binding SelectedSchedulerConfiguration.TertiaryStrategy, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Border Background="#1F2730" CornerRadius="4" Padding="8" Margin="0,0,0,6"
                                                        Visibility="{Binding IsWeightedPrioritizationSelectedForConfig, Converter={StaticResource BoolToVisConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Text="Weighted Prioritization" Foreground="#9CDCFE" FontSize="11" FontWeight="SemiBold"/>
                                                        <TextBlock Text="All metrics stay visible here. Set weight to 0 to disable one. Thresholds define where a metric reaches zero score and full score." Foreground="#A0A0A0" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,6"/>
                                                        <Border Background="#161616" CornerRadius="3" Padding="6,5" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2*"/>
                                                                    <ColumnDefinition Width="50"/>
                                                                    <ColumnDefinition Width="95"/>
                                                                    <ColumnDefinition Width="70"/>
                                                                    <ColumnDefinition Width="70"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="Metric" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="1" Text="Weight" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="2" Text="Prefer Higher" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="3" Text="Zero" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="4" Text="Full" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                            </Grid>
                                                        </Border>
