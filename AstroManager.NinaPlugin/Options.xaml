                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Observatory.Name}" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Latitude:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#4EC9B0" FontSize="11" Margin="0,0,0,6">
                                                <Run Text="{Binding Observatory.Latitude, StringFormat='{}{0:F5}°'}"/>
                                            </TextBlock>
                                            
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Longitude:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Foreground="#4EC9B0" FontSize="11" Margin="0,0,0,6">
                                                <Run Text="{Binding Observatory.Longitude, StringFormat='{}{0:F5}°'}"/>
                                            </TextBlock>
                                            
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Elevation:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Foreground="#4EC9B0" FontSize="11" Margin="0,0,0,6">
                                                <Run Text="{Binding Observatory.Elevation, StringFormat='{}{0:F0} m'}"/>
                                            </TextBlock>
                                            
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Min Altitude:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Foreground="#D7BA7D" FontSize="11" Margin="0,0,0,6">
                                                <Run Text="{Binding Observatory.MinAltitude, StringFormat='{}{0:F0}°'}"/>
                                            </TextBlock>
                                            
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Timezone:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Observatory.TimeZoneId}" Foreground="#909090" FontSize="11" Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>
                                            
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Custom Horizon:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,6"/>
                                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="✓" Foreground="#4EC9B0" FontSize="11" Visibility="{Binding ObservatoryHasCustomHorizon, Converter={StaticResource BoolToVisConverter}}"/>
                                                <TextBlock Text="✗" Foreground="#909090" FontSize="11" Visibility="{Binding ObservatoryHasCustomHorizon, Converter={StaticResource InverseBoolToVisConverter}}"/>
                                                <TextBlock Text="{Binding ObservatoryCustomHorizonPointCount, StringFormat=' ({0} points)'}" Foreground="#909090" FontSize="11" 
                                                           Visibility="{Binding ObservatoryHasCustomHorizon, Converter={StaticResource BoolToVisConverter}}"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <TextBlock Text="No observatory data loaded" Foreground="#909090" FontSize="11" FontStyle="Italic"
                                                   Visibility="{Binding HasObservatory, Converter={StaticResource InverseBoolToVisConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Expander>
                
                <!-- Row 4: Targets (Collapsible) -->
                <Expander Style="{StaticResource ExpanderStyle}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#569CD6"/>
                            <TextBlock Text="Targets" FontSize="13" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                            <TextBlock Text="{Binding CachedTargetCount, StringFormat=' ({0})'}" Foreground="#C0C0C0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                        <StackPanel>
                            <!-- Scheduler Mode Toggle -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SchedulerModeDisplay}" Foreground="#E0E0E0" FontSize="12"/>
                                    <TextBlock Text="{Binding SchedulerModeDescription}" Foreground="#707070" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource CheckBoxStyle}" 
                                          IsChecked="{Binding IsManualMode, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          ToolTip="Toggle between Auto (scheduler picks targets) and Manual (you control target queue) mode.">
                                    <TextBlock Text="Manual" Foreground="#E0E0E0"/>
                                </CheckBox>
                            </Grid>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <Button Content="🔄 Reload from API" Command="{Binding RefreshTargetsListCommand}" Style="{StaticResource SecondaryButton}" ToolTip="Reload targets from server"/>
                            </StackPanel>
                            
                            <!-- Queue Management (visible in Manual mode) -->
                            <Border BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Margin="0,0,0,10" Padding="0,0,0,10"
                                    Visibility="{Binding IsManualMode, Converter={StaticResource BoolToVisConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Target Queue -->
                                    <StackPanel Grid.Column="0">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🎯 Target Queue" Foreground="#4EC9B0" FontSize="11" FontWeight="SemiBold"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Style="{StaticResource SmallButton}" Command="{Binding RefreshQueueCommand}" 
                                                        ToolTip="Refresh queue" Margin="0,0,2,0" Padding="6,2">
                                                    <TextBlock Text="↻" Foreground="#E0E0E0" FontSize="12"/>
                                                </Button>
                                                <Button Style="{StaticResource SmallButton}" Command="{Binding ClearQueueCommand}"
                                                        ToolTip="Clear all" Padding="6,2">
                                                    <TextBlock Text="✕" Foreground="#E06C75" FontSize="12"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <Border Background="#1E1E1E" CornerRadius="4" Padding="4" MinHeight="80">
                                            <Grid>
                                                <TextBlock Text="Queue empty" Foreground="#606060" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding TargetQueue.Count, Converter={StaticResource ZeroToVisConverter}}"/>
                                                <ListBox ItemsSource="{Binding TargetQueue}" SelectedItem="{Binding SelectedQueueItem, Mode=TwoWay}"
                                                         Background="Transparent" BorderThickness="0" MaxHeight="100"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="18"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding QueueOrder}" Foreground="#4EC9B0" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding TargetName}" Foreground="#E0E0E0" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                                <Border Grid.Column="2" CornerRadius="2" Padding="4,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#3C3C3C"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Active">
                                                                                    <Setter Property="Background" Value="#2D7D46"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                                    <Setter Property="Background" Value="#0E639C"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                                                    <Setter Property="Background" Value="#B8860B"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                                    <Setter Property="Background" Value="#C42B1C"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding Status}" FontSize="8" Foreground="White"/>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Style="{StaticResource SmallButton}" Command="{Binding MoveUpCommand}" 
                                                    ToolTip="Move up" Padding="8,2" Margin="0,0,2,0">
                                                <TextBlock Text="▲" Foreground="#E0E0E0" FontSize="10"/>
                                            </Button>
                                            <Button Style="{StaticResource SmallButton}" Command="{Binding MoveDownCommand}"
                                                    ToolTip="Move down" Padding="8,2" Margin="0,0,2,0">
                                                <TextBlock Text="▼" Foreground="#E0E0E0" FontSize="10"/>
                                            </Button>
                                            <Button Style="{StaticResource SmallButton}" Command="{Binding RemoveFromQueueCommand}"
                                                    ToolTip="Remove from queue" Padding="8,2" Margin="0,0,2,0">
                                                <TextBlock Text="✕" Foreground="#E06C75" FontSize="10"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Available Targets for Queue -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="📋 Available Targets" Foreground="#909090" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <Border Background="#1E1E1E" CornerRadius="4" Padding="4" MinHeight="80">
                                            <Grid>
                                                <TextBlock Text="No targets" Foreground="#606060" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding AvailableTargets.Count, Converter={StaticResource ZeroToVisConverter}}"/>
                                                <ListBox ItemsSource="{Binding AvailableTargets}" SelectedItem="{Binding SelectedAvailableTarget, Mode=TwoWay}"
                                                         Background="Transparent" BorderThickness="0" MaxHeight="100"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,1"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </Border>
                                        <Button Style="{StaticResource SmallButton}" Command="{Binding AddToQueueCommand}"
                                                HorizontalAlignment="Left" Margin="0,4,0,0" Padding="8,3">
                                            <TextBlock Text="+ Add to Queue" Foreground="#E0E0E0" FontSize="10"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*" MinWidth="400"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Target List with Search, Group, and Filter -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                <!-- Search Box -->
                                <Grid Margin="0,0,0,4">
                                    <TextBox Text="{Binding TargetSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#3C3C3C" Foreground="#E0E0E0" BorderBrush="#4A4A4A" 
                                             Padding="6,4" FontSize="12" ToolTip="Search targets by name"/>
                                    <TextBlock Text="🔍 Search..." Foreground="#909090" FontSize="10" Margin="0,0,8,0" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False"
                                               Visibility="{Binding HasTargetSearchText, Converter={StaticResource InverseBoolToVisConverter}}"/>
                                </Grid>
                                <!-- Group By and Filter Row -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding TargetGroupByOptions}" 
                                              SelectedItem="{Binding TargetGroupBy, Mode=TwoWay}"
                                              Background="#3C3C3C" Foreground="#E0E0E0" FontSize="10" Padding="4,2" MinHeight="22"
                                              ToolTip="Group targets by"/>
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding TargetFilterOptions}" 
                                              SelectedItem="{Binding TargetFilterBy, Mode=TwoWay}"
                                              Background="#3C3C3C" Foreground="#E0E0E0" FontSize="10" Padding="4,2" MinHeight="22"
                                              ToolTip="Filter targets"/>
                                </Grid>
                            </StackPanel>
                            <!-- Collapsible Target Groups -->
                            <ScrollViewer Grid.Column="0" Height="220" Margin="0,54,0,0"
                                          VerticalAlignment="Top"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="#1E1E1E">
                                <ItemsControl ItemsSource="{Binding CollapsibleTargetGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Style="{StaticResource TargetGroupExpanderStyle}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,0,0,2">
                                                <Expander.Header>
                                                    <Grid Width="220">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold" Foreground="#569CD6" FontSize="12"/>
                                                        <TextBlock Grid.Column="1" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center">
                                                            <Run Text="("/>
                                                            <Run Text="{Binding TargetCount, Mode=OneWay}"/>
                                                            <Run Text=")"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Expander.Header>
                                                <Expander.Content>
                                                    <ListBox ItemsSource="{Binding Targets}" 
                                                             SelectedItem="{Binding DataContext.SelectedTarget, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                             Background="Transparent" 
                                                             BorderThickness="0"
                                                             Margin="12,0,0,0">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="4,3">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- Row 1: Name + Mosaic indicator + Status + Priority -->
                                                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="12"/>
                                                                        <TextBlock Text=" M" FontWeight="Bold" Foreground="#C586C0" FontSize="10" VerticalAlignment="Center"
                                                                                   Visibility="{Binding IsMosaic, Converter={StaticResource BoolToVisConverter}}"
                                                                                   ToolTip="Mosaic target"/>
                                                                    </StackPanel>
                                                                    <Border Grid.Row="0" Grid.Column="1" CornerRadius="3" Padding="4,1" Margin="6,0" VerticalAlignment="Center">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="#3C3C3C"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Active">
                                                                                        <Setter Property="Background" Value="#2D7D46"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                                        <Setter Property="Background" Value="#B8860B"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                                        <Setter Property="Background" Value="#0E639C"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding Status}" FontSize="9" Foreground="White"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Priority, StringFormat='P{0}'}" 
                                                                               Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Width="25"/>
                                                                    <!-- Row 2: Object Type + Goals count + Panel count (if mosaic) + Completion % -->
                                                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,2,0,0">
                                                                        <TextBlock Foreground="#C0C0C0" FontSize="10">
                                                                            <Run Text="{Binding ObjectType, Mode=OneWay}"/>
                                                                            <Run Text=" • "/>
                                                                            <Run Text="{Binding ImagingGoals.Count, Mode=OneWay, StringFormat='{}{0} goals'}"/>
                                                                        </TextBlock>
                                                                        <TextBlock Foreground="#C586C0" FontSize="10" Visibility="{Binding IsMosaic, Converter={StaticResource BoolToVisConverter}}">
                                                                            <Run Text=" • "/>
                                                                            <Run Text="{Binding Panels.Count, Mode=OneWay, StringFormat='{}{0} panels'}"/>
                                                                        </TextBlock>
                                                                        <TextBlock Foreground="#C0C0C0" FontSize="10">
                                                                            <Run Text=" • "/>
                                                                            <Run Text="{Binding CompletionPercentage, Mode=OneWay, StringFormat='{}{0:F0}%'}" Foreground="#4EC9B0"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Expander.Content>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <!-- Empty State -->
                            <TextBlock Grid.Column="0" Text="No targets synced yet.&#x0a;Click 'Sync Targets' to fetch your targets."
                                       Foreground="#909090" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                       Visibility="{Binding CachedTargetCount, Converter={StaticResource ZeroToVisConverter}}" FontSize="12"/>
                            
                            <!-- Selected Target Details -->
                            <Border Grid.Column="2" Background="#252526" CornerRadius="4" Padding="10"
                                    VerticalAlignment="Top"
                                    Visibility="{Binding HasSelectedTarget, Converter={StaticResource BoolToVisConverter}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="580">
                                    <StackPanel>
                                        <!-- 1. BASE DATA Section -->
                                        <Expander IsExpanded="True" Margin="0,0,0,4">
                                            <Expander.Header>
                                                <TextBlock Text="🎯 BASE DATA" FontWeight="SemiBold" Foreground="#569CD6" FontSize="12"/>
                                            </Expander.Header>
                                            <Border Background="#1E1E1E" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                                <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="55"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="55"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}" ToolTip="Target name (e.g., 'M31', 'NGC 7000')"/>
                                                <TextBox Style="{StaticResource InputBox}" 
                                                         Text="{Binding EditableTargetName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         ToolTip="Target name for identification"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Status" Style="{StaticResource FieldLabel}" ToolTip="Active=will be scheduled, Paused=temporarily skip, Completed=done imaging"/>
                                                <ComboBox ItemsSource="{Binding StatusValues}" 
                                                          SelectedItem="{Binding EditableStatus, Mode=TwoWay}"
                                                          Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="6,4" MinHeight="28"
                                                          ToolTip="Active=schedule normally | Paused=skip temporarily | Completed=finished"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Priority" Style="{StaticResource FieldLabel}" ToolTip="Scheduling priority: 1=highest (scheduled first), 99=lowest"/>
                                                <TextBox Style="{StaticResource InputBox}" 
                                                         Text="{Binding EditablePriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Priority 1-99 (1=highest, scheduled first)"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="6">
                                                <TextBlock Text="Goal Multiplier" Style="{StaticResource FieldLabel}" ToolTip="Multiplies all imaging goal shot counts (e.g., 3 = shoot 3x the goal for each filter)"/>
                                                <TextBox Style="{StaticResource InputBox}" 
                                                         Text="{Binding EditableRepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Goal multiplier (1=standard goals, 3=triple all goal counts)"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding SelectedTargetObjectType}" Foreground="#C0C0C0" FontSize="12" Margin="0,0,0,12"/>
                                        
                                        <!-- Coordinates (HMS/DMS - J2000) + Scheduler Template -->
                                        <TextBlock Text="📍 COORDINATES &amp; TEMPLATE" Foreground="#569CD6" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- RA with 3 fields -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="RA (h m s)" Foreground="#C0C0C0" FontSize="12" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Style="{StaticResource InputBox}" Width="40"
                                                             Text="{Binding EditableRAHours, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             ToolTip="Hours (0-23)"/>
                                                    <TextBlock Text="h" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="3,0,8,0" FontSize="12"/>
                                                    <TextBox Style="{StaticResource InputBox}" Width="40"
                                                             Text="{Binding EditableRAMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             ToolTip="Minutes (0-59)"/>
                                                    <TextBlock Text="m" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="3,0,8,0" FontSize="12"/>
                                                    <TextBox Style="{StaticResource InputBox}" Width="50"
                                                             Text="{Binding EditableRASeconds, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             ToolTip="Seconds (0-59.99)"/>
                                                    <TextBlock Text="s" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="3,0,0,0" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- DEC with 3 fields -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="DEC (° ' &quot;)" Foreground="#C0C0C0" FontSize="12" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Style="{StaticResource InputBox}" Width="50"
                                                             Text="{Binding EditableDecDegrees, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             ToolTip="Degrees (-90 to +90)"/>
                                                    <TextBlock Text="°" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="3,0,8,0" FontSize="12"/>
                                                    <TextBox Style="{StaticResource InputBox}" Width="40"
                                                             Text="{Binding EditableDecMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             ToolTip="Arcminutes (0-59)"/>
                                                    <TextBlock Text="'" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="3,0,8,0" FontSize="12"/>
                                                    <TextBox Style="{StaticResource InputBox}" Width="50"
                                                             Text="{Binding EditableDecSeconds, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             ToolTip="Arcseconds (0-59.99)"/>
                                                    <TextBlock Text="&quot;" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="3,0,0,0" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- Scheduler Template (inline) -->
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Scheduler Template" Foreground="#C0C0C0" FontSize="12" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <ComboBox ItemsSource="{Binding SchedulerTargetTemplates}" 
                                                              SelectedItem="{Binding SelectedTargetSchedulerTemplate, Mode=TwoWay}"
                                                              DisplayMemberPath="Name"
                                                              Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26" MinWidth="120"
                                                              ToolTip="Apply a scheduler template to override scheduling settings for this target"/>
                                                    <Button Content="✕" Command="{Binding ClearTargetTemplateCommand}" 
                                                            Background="Transparent" Foreground="#909090" BorderThickness="0" 
                                                            Padding="6,2" FontSize="12" Cursor="Hand" ToolTip="Clear template" Margin="2,0,0,0"
                                                            Visibility="{Binding HasSelectedTargetSchedulerTemplate, Converter={StaticResource BoolToVisConverter}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Position Angle & Auto-Rotation -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Position Angle (°)" Foreground="#C0C0C0" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource InputBox}" Width="80"
                                                         Text="{Binding EditablePositionAngle, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         ToolTip="Sky position angle in degrees (0-360). Used automatically if rotator is connected."/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                                <TextBlock Text="Used if rotator connected" Foreground="#808080" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Expander>
                                        
                                        <!-- 2. MOSAIC SETTINGS Section -->
                                        <Expander IsExpanded="{Binding SelectedTargetIsMosaic, Mode=OneWay}" Margin="0,0,0,4">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <CheckBox IsChecked="{Binding EditableIsMosaic, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="🔲 MOSAIC SETTINGS" FontWeight="SemiBold" Foreground="#C586C0" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </Expander.Header>
                                            <Border Background="#1E1E1E" CornerRadius="4" Padding="8" Margin="0,4,0,0"
                                                    Visibility="{Binding ShowMosaicSettings, Converter={StaticResource BoolToVisConverter}}">
                                        <StackPanel>
                                            <!-- Row 1: Panels X, Y, Overlap -->
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Panels X" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Style="{StaticResource InputBox}" 
                                                             Text="{Binding EditableMosaicPanelsX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="Number of panels horizontally"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Panels Y" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Style="{StaticResource InputBox}" 
                                                             Text="{Binding EditableMosaicPanelsY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="Number of panels vertically"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="Overlap %" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Style="{StaticResource InputBox}" 
                                                             Text="{Binding EditableMosaicOverlapPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="Panel overlap percentage (0-100)"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Row 2: Shooting Strategy, Panel Ordering, Goal Ordering -->
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Shooting Strategy" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox ItemsSource="{Binding MosaicShootingStrategyDisplayValues}" 
                                                              SelectedValue="{Binding EditableMosaicShootingStrategy, Mode=TwoWay}"
                                                              SelectedValuePath="Key" DisplayMemberPath="Value"
                                                              Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"
                                                              ToolTip="Sequential=complete one panel before next, Parallel=rotate through panels"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Panel Ordering" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox ItemsSource="{Binding MosaicPanelOrderingDisplayValues}" 
                                                              SelectedValue="{Binding EditableMosaicPanelOrderingMethod, Mode=TwoWay}"
                                                              SelectedValuePath="Key" DisplayMemberPath="Value"
                                                              Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"
                                                              ToolTip="Manual=user-defined order, Auto=by observability"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="Goal Ordering" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox ItemsSource="{Binding GoalOrderingDisplayValues}" 
                                                              SelectedValue="{Binding EditableGoalOrderingMethod, Mode=TwoWay}"
                                                              SelectedValuePath="Key" DisplayMemberPath="Value"
                                                              Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"
                                                              ToolTip="Order of goal execution"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Row 3: Toggle options with proper labels -->
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <CheckBox IsChecked="{Binding EditableMosaicUseRotator, Mode=TwoWay}" VerticalAlignment="Center"
                                                              ToolTip="Rotate panel layout for optimal sky alignment. Requires a rotator to be connected during imaging."/>
                                                    <TextBlock Text="Rotate Panels" Foreground="#C0C0C0" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"
                                                               ToolTip="Rotate panel layout for optimal sky alignment. Requires a rotator to be connected during imaging."/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <CheckBox IsChecked="{Binding EditableUseCustomPanelGoals, Mode=TwoWay}" VerticalAlignment="Center"
                                                              ToolTip="Enable to set different imaging goals per panel"/>
                                                    <TextBlock Text="Custom Panel Goals" Foreground="#C0C0C0" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"
                                                               ToolTip="Each panel has separate imaging goals"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                            </Border>
                                        </Expander>
                                        
                                        <!-- 3. IMAGING GOALS Section -->
                                        <Expander IsExpanded="True" Margin="0,0,0,4">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🎨 IMAGING GOALS" FontWeight="SemiBold" Foreground="#4EC9B0" FontSize="12"/>
                                                    <TextBlock Text="{Binding SelectedTargetImagingGoals.Count, StringFormat=' ({0})'}" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Expander.Header>
                                            <Border Background="#1E1E1E" CornerRadius="4" Padding="8">
                                                <StackPanel>
                                        <!-- Mosaic Panel Goals Note -->
                                        <Border Background="#2D2D30" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                                                Visibility="{Binding SelectedTargetUseCustomPanelGoals, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="ℹ️ Custom panel goals enabled. Goals below are base goals synced to all panels. Select a panel below to add/edit panel-specific overrides." 
                                                       Foreground="#D69D29" FontSize="10" TextWrapping="Wrap"/>
                                        </Border>
                                        <ListBox ItemsSource="{Binding SelectedTargetImagingGoals}" 
                                                 SelectedItem="{Binding SelectedImagingGoalWrapper, Mode=TwoWay}"
                                                 Background="Transparent" BorderBrush="Transparent" Margin="0,0,0,6"
                                                 MaxHeight="120">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="4" Padding="8,6" Margin="0,0,6,6" BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#252526"/>
                                                                <Setter Property="BorderBrush" Value="#3C3C3C"/>
                                                                <Setter Property="Opacity" Value="1"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                        <Setter Property="Background" Value="#1A1A1A"/>
                                                                        <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                                                        <Setter Property="Opacity" Value="0.6"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock Text="{Binding Filter}" FontWeight="SemiBold" Foreground="#569CD6" FontSize="12"/>
                                                                <TextBlock Text=" ⏸" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center"
                                                                           Visibility="{Binding IsEnabled, Converter={StaticResource InverseBoolToVisConverter}}"
                                                                           ToolTip="Goal is disabled"/>
                                                                <TextBlock Text="{Binding ExposureTimeSeconds, StringFormat=' {0}s'}" Foreground="#B0B0B0" FontSize="12" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <ProgressBar Value="{Binding CompletionPercentage, Mode=OneWay}" Maximum="100" Height="5" Width="90" Background="#3C3C3C" Foreground="#4EC9B0" HorizontalAlignment="Left"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <TextBlock Foreground="#C0C0C0" FontSize="12">
                                                                    <Run Text="{Binding CompletedExposures, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding GoalExposureCount, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding CompletionPercentage, StringFormat=' {0}%'}" Foreground="#4EC9B0" FontWeight="SemiBold" FontSize="12" Margin="4,0,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        
                                        <!-- Add Goal Button -->
                                        <Button Content="+ Add Goal" Command="{Binding AddImagingGoalCommand}" 
                                                Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="10" 
                                                HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                        
                                        <!-- Selected Imaging Goal Edit -->
                                        <Border Background="#1A1A1A" CornerRadius="4" Padding="12" Margin="0,0,0,12"
                                                Visibility="{Binding HasSelectedImagingGoal, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="✏️ EDIT IMAGING GOAL" Foreground="#D69D29" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Exposure Template" Style="{StaticResource FieldLabel}" ToolTip="Select an exposure template that defines filter, exposure time, gain, offset, etc."/>
                                                        <ComboBox ItemsSource="{Binding ExposureTemplates}" 
                                                                  SelectedValue="{Binding EditableImagingGoalExposureTemplateId, Mode=TwoWay}"
                                                                  SelectedValuePath="Id" DisplayMemberPath="Name"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"
                                                                  ToolTip="Exposure template defines filter, exposure time, gain, offset, binning"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Goal Count" Style="{StaticResource FieldLabel}" ToolTip="Target number of sub-frames to capture"/>
                                                        <TextBox Style="{StaticResource InputBox}"
                                                                 Text="{Binding EditableImagingGoalCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Number of exposures to capture (e.g., 50)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                                        <StackPanel Orientation="Horizontal">
                                                            <CheckBox IsChecked="{Binding EditableImagingGoalIsEnabled, Mode=TwoWay}" VerticalAlignment="Center"
                                                                      ToolTip="Enable or disable this imaging goal for scheduling"/>
                                                            <TextBlock Text="Enabled" Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Display read-only settings from selected template (single compact row) -->
                                                <Border Background="#252526" CornerRadius="3" Padding="6,4" Margin="0,0,0,8"
                                                        Visibility="{Binding HasSelectedImagingGoal, Converter={StaticResource BoolToVisConverter}}">
                                                    <WrapPanel Orientation="Horizontal">
                                                        <TextBlock Foreground="#569CD6" FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0">
                                                            <Run Text="{Binding SelectedImagingGoal.Filter, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                            <Run Text="{Binding SelectedImagingGoal.ExposureTimeSeconds, Mode=OneWay}"/><Run Text="s"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                            <Run Text="Bin "/><Run Text="{Binding SelectedImagingGoal.Binning, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                            <Run Text="G"/><Run Text="{Binding SelectedImagingGoal.Gain, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                            <Run Text="O"/><Run Text="{Binding SelectedImagingGoal.Offset, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#4EC9B0" FontSize="10" Margin="0,0,8,0">
                                                            <Run Text="P"/><Run Text="{Binding SelectedImagingGoal.FilterPriority, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                            <Run Text="Dith "/><Run Text="{Binding SelectedImagingGoal.ExposureTemplate.DitherEveryX, Mode=OneWay, TargetNullValue='-'}"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                            <Run Text="Alt≥"/><Run Text="{Binding SelectedImagingGoal.ExposureTemplate.MinAltitude, Mode=OneWay, TargetNullValue='-'}"/><Run Text="°"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0" Text="{Binding SelectedImagingGoal.ExposureTemplate.AcceptableTwilight, Mode=OneWay}"/>
                                                        <TextBlock Foreground="#909090" FontSize="10" Text="{Binding SelectedImagingGoalMoonAvoidanceProfileName, TargetNullValue='', Mode=OneWay}" TextTrimming="CharacterEllipsis"/>
                                                    </WrapPanel>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Button Content="💾 Save" Command="{Binding SaveImagingGoalCommand}" Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                                                    <Button Content="Cancel" Command="{Binding CancelImagingGoalEditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                                    <Button Content="🗑️ Delete" Command="{Binding DeleteImagingGoalCommand}" Background="#6B3030" Foreground="#E0E0E0" BorderThickness="0" Padding="10,6" Cursor="Hand"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Panel Goals Section (Mosaics only - after base goals) -->
                                        <Border Background="#1A1A1A" CornerRadius="4" Padding="12" Margin="0,0,0,12"
                                                Visibility="{Binding SelectedTargetIsMosaic, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="🔲 PANEL GOALS" Foreground="#C586C0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding SelectedTargetPanels.Count, StringFormat=' ({0} panels)'}" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="0,1,0,0"/>
                                                </StackPanel>
                                                
                                                <!-- Panel Selector -->
                                                <ComboBox ItemsSource="{Binding SelectedTargetPanels}" 
                                                          SelectedItem="{Binding SelectedPanel, Mode=TwoWay}"
                                                          Background="#3C3C3C" Foreground="#E0E0E0" FontSize="10" Padding="4,2" MinHeight="22" Margin="0,0,0,8" MaxWidth="220" HorizontalAlignment="Left">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontSize="10">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#C586C0"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                                    <Setter Property="Foreground" Value="#606060"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                    <Run Text="P"/><Run Text="{Binding PanelNumber, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding ShootingOrder, StringFormat=' (#{0})', TargetNullValue=''}" 
                                                                           FontSize="9" Foreground="#909090" VerticalAlignment="Center"
                                                                           ToolTip="Manual shooting order (lower = shoots first)"/>
                                                                <TextBlock Text=" ⏸" Foreground="#909090" FontSize="9" VerticalAlignment="Center"
                                                                           Visibility="{Binding IsEnabled, Converter={StaticResource InverseBoolToVisConverter}}"
                                                                           ToolTip="Panel disabled"/>
                                                                <TextBlock Text="{Binding CompletionPercentage, StringFormat=' {0:F0}%'}" Foreground="#4EC9B0" FontSize="10" Margin="4,0,0,0"/>
                                                                <TextBlock Text="{Binding CustomGoalCount, StringFormat=' • {0} custom'}" Foreground="#D69D29" FontSize="10" Margin="4,0,0,0"
                                                                           Visibility="{Binding HasCustomGoals, Converter={StaticResource BoolToVisConverter}}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                
                                                <!-- Panel Enable/Disable Toggle and Shooting Order -->
                                                <Grid Margin="0,0,0,8"
                                                      Visibility="{Binding HasSelectedPanel, Converter={StaticResource BoolToVisConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <CheckBox IsChecked="{Binding SelectedPanelIsEnabled, Mode=TwoWay}" 
                                                                  VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Panel Enabled" Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <TextBlock Text="Shooting Order:" Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                   ToolTip="Lower number = shoots first. Used when Panel Ordering is set to Manual."/>
                                                        <TextBox Style="{StaticResource InputBox}" Width="40" FontSize="10" Padding="4,2"
                                                                 Text="{Binding SelectedPanelShootingOrder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Lower number = shoots first (1, 2, 3...). Leave empty for default order."/>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Panel Coordinates (read-only) -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                                            Visibility="{Binding HasSelectedPanel, Converter={StaticResource BoolToVisConverter}}">
                                                    <TextBlock Text="RA:" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Width="25"/>
                                                    <TextBlock Text="{Binding SelectedPanelRaDisplay}" Foreground="#569CD6" FontSize="10" VerticalAlignment="Center" Width="75" FontFamily="Consolas"/>
                                                    <TextBlock Text="Dec:" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Width="30" Margin="8,0,0,0"/>
                                                    <TextBlock Text="{Binding SelectedPanelDecDisplay}" Foreground="#569CD6" FontSize="10" VerticalAlignment="Center" Width="80" FontFamily="Consolas"/>
                                                    <TextBlock Text="PA:" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Width="25" Margin="8,0,0,0"/>
                                                    <TextBlock Text="{Binding SelectedPanelPaDisplay}" Foreground="#569CD6" FontSize="10" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                </StackPanel>
                                                
                                                <!-- Selected Panel Goals List (read-only for base, selectable for custom) -->
                                                <Border Background="#252526" CornerRadius="3" Padding="8"
                                                        Visibility="{Binding HasSelectedPanel, Converter={StaticResource BoolToVisConverter}}">
                                                    <StackPanel>
                                                        <!-- Base Goals (read-only) -->
                                                        <TextBlock Text="Base Goals" Foreground="#B0B0B0" FontSize="10" Margin="0,0,0,4"/>
                                                        <ItemsControl ItemsSource="{Binding SelectedPanelBaseGoals}" Margin="0,0,0,8">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#1E1E1E" Padding="8,5" Margin="0,0,4,4" CornerRadius="3">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Filter}" FontWeight="SemiBold" Foreground="#569CD6" FontSize="12"/>
                                                                            <TextBlock Foreground="#C0C0C0" FontSize="12" Margin="6,0,0,0">
                                                                                <Run Text="{Binding CompletedExposures, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding GoalExposureCount, Mode=OneWay}"/>
                                                                            </TextBlock>
                                                                            <TextBlock Text="{Binding CompletionPercentage, StringFormat=' {0:F0}%'}" Foreground="#4EC9B0" FontSize="12" Margin="4,0,0,0"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        
                                                        <!-- Custom Goals (selectable/editable) -->
                                                        <TextBlock Text="Custom Goals (click to edit)" Foreground="#D69D29" FontSize="10" Margin="0,0,0,4"
                                                                   Visibility="{Binding SelectedTargetUseCustomPanelGoals, Converter={StaticResource BoolToVisConverter}}"/>
                                                        <ListBox ItemsSource="{Binding SelectedPanelCustomGoals}" 
                                                                 SelectedItem="{Binding SelectedPanelGoal, Mode=TwoWay}"
                                                                 Background="Transparent" BorderBrush="Transparent" MaxHeight="100"
                                                                 Visibility="{Binding SelectedTargetUseCustomPanelGoals, Converter={StaticResource BoolToVisConverter}}">
                                                            <ListBox.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ListBox.ItemsPanel>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#2D2D30" BorderBrush="#D69D29" BorderThickness="1" Padding="8,5" Margin="0,0,4,4" CornerRadius="3">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Filter}" FontWeight="SemiBold" Foreground="#D69D29" FontSize="12"/>
                                                                            <TextBlock Foreground="#C0C0C0" FontSize="12" Margin="6,0,0,0">
                                                                                <Run Text="{Binding CompletedExposures, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding GoalExposureCount, Mode=OneWay}"/>
                                                                            </TextBlock>
                                                                            <TextBlock Text="{Binding CompletionPercentage, StringFormat=' {0:F0}%'}" Foreground="#4EC9B0" FontSize="12" Margin="4,0,0,0"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                        
                                                        <!-- No custom goals message -->
                                                        <TextBlock Text="No custom goals for this panel." Foreground="#909090" FontSize="10" FontStyle="Italic"
                                                                   Visibility="{Binding SelectedPanelCustomGoals.Count, Converter={StaticResource ZeroToVisConverter}}"/>
                                                        
                                                        <!-- Add Custom Goal Button -->
                                                        <Button Content="+ Custom Goal" Command="{Binding AddPanelCustomGoalCommand}" 
                                                                Style="{StaticResource SecondaryButton}" Padding="6,2" FontSize="9"
                                                                HorizontalAlignment="Left" Margin="0,8,0,0">
                                                            <Button.Visibility>
                                                                <MultiBinding Converter="{StaticResource MultiBoolToVisConverter}">
                                                                    <Binding Path="HasSelectedPanel"/>
                                                                    <Binding Path="SelectedTargetUseCustomPanelGoals"/>
                                                                </MultiBinding>
                                                            </Button.Visibility>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- Edit Selected Panel Goal -->
                                                <Border Background="#1E1E1E" CornerRadius="3" Padding="10" Margin="0,8,0,0"
                                                        Visibility="{Binding HasSelectedPanelGoal, Converter={StaticResource BoolToVisConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Text="✏️ EDIT PANEL GOAL" Foreground="#C586C0" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="70"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="Exposure Template" Style="{StaticResource FieldLabel}"/>
                                                                <ComboBox ItemsSource="{Binding ExposureTemplates}" 
                                                                          SelectedValue="{Binding EditablePanelGoalExposureTemplateId, Mode=TwoWay}"
                                                                          SelectedValuePath="Id" DisplayMemberPath="Name"
                                                                          Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Goal Count" Style="{StaticResource FieldLabel}"/>
                                                                <TextBox Style="{StaticResource InputBox}"
                                                                         Text="{Binding EditablePanelGoalCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <CheckBox IsChecked="{Binding EditablePanelGoalIsEnabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="Enabled" Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                        <!-- Template details (single compact row) -->
                                                        <Border Background="#252526" CornerRadius="3" Padding="6,4" Margin="0,0,0,8">
                                                            <WrapPanel Orientation="Horizontal">
                                                                <TextBlock Foreground="#569CD6" FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0">
                                                                    <Run Text="{Binding SelectedPanelGoal.Filter, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                                    <Run Text="{Binding SelectedPanelGoal.ExposureTimeSeconds, Mode=OneWay}"/><Run Text="s"/>
                                                                </TextBlock>
                                                                <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                                    <Run Text="Bin "/><Run Text="{Binding SelectedPanelGoal.ExposureTemplate.Binning, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                                    <Run Text="G"/><Run Text="{Binding SelectedPanelGoal.ExposureTemplate.Gain, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                                    <Run Text="O"/><Run Text="{Binding SelectedPanelGoal.ExposureTemplate.Offset, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Foreground="#4EC9B0" FontSize="10" Margin="0,0,8,0">
                                                                    <Run Text="P"/><Run Text="{Binding SelectedPanelGoal.FilterPriority, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                                    <Run Text="Dith "/><Run Text="{Binding SelectedPanelGoal.ExposureTemplate.DitherEveryX, Mode=OneWay, TargetNullValue='-'}"/>
                                                                </TextBlock>
                                                                <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0">
                                                                    <Run Text="Alt≥"/><Run Text="{Binding SelectedPanelGoal.ExposureTemplate.MinAltitude, Mode=OneWay, TargetNullValue='-'}"/><Run Text="°"/>
                                                                </TextBlock>
                                                                <TextBlock Foreground="#909090" FontSize="10" Margin="0,0,8,0" Text="{Binding SelectedPanelGoal.ExposureTemplate.AcceptableTwilight, Mode=OneWay}"/>
                                                                <TextBlock Foreground="#909090" FontSize="10" Text="{Binding SelectedPanelGoalMoonAvoidanceProfileName, TargetNullValue='', Mode=OneWay}" TextTrimming="CharacterEllipsis"/>
                                                            </WrapPanel>
                                                        </Border>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="💾 Save" Command="{Binding SavePanelGoalCommand}" Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                                                            <Button Content="Cancel" Command="{Binding CancelPanelGoalEditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                                            <Button Content="🗑️ Delete" Command="{Binding DeletePanelGoalCommand}" Background="#6B3030" Foreground="#E0E0E0" BorderThickness="0" Padding="10,6" Cursor="Hand"
                                                                    Visibility="{Binding SelectedPanelGoal.IsCustomGoal, Converter={StaticResource BoolToVisConverter}}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                                </StackPanel>
                                            </Border>
                                        </Expander>
                                        
                                        <!-- 4. IMAGE STATISTICS Section -->
                                        <Expander IsExpanded="False" Margin="0,0,0,4">
                                            <Expander.Header>
                                                <TextBlock Text="📈 IMAGE STATISTICS" FontWeight="SemiBold" Foreground="#D69D29" FontSize="12"/>
                                            </Expander.Header>
                                            <Border Background="#1E1E1E" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Row 1 -->
                                                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                    <TextBlock Text="INTEGRATION" Foreground="#C0C0C0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ImageStatsIntegration}" Foreground="#4EC9B0" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                    <TextBlock Text="AVG FWHM" Foreground="#C0C0C0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ImageStatsAvgFwhm}" Foreground="#E0E0E0" FontSize="12" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                    <TextBlock Text="BEST FWHM" Foreground="#C0C0C0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ImageStatsBestFwhm}" Foreground="#4EC9B0" FontSize="12" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="3" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                    <TextBlock Text="AVG HFD" Foreground="#C0C0C0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ImageStatsAvgHfd}" Foreground="#E0E0E0" FontSize="12" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <!-- Row 2 -->
                                                <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                    <TextBlock Text="AVG SNR" Foreground="#C0C0C0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ImageStatsAvgSnr}" Foreground="#E0E0E0" FontSize="12" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                    <TextBlock Text="STARS" Foreground="#C0C0C0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ImageStatsStarCount}" Foreground="#E0E0E0" FontSize="12" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                    <TextBlock Text="ECCENTRICITY" Foreground="#C0C0C0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ImageStatsEccentricity}" Foreground="#E0E0E0" FontSize="12" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                    <TextBlock Text="ACCEPT RATE" Foreground="#C0C0C0" FontSize="9" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ImageStatsAcceptanceRate}" Foreground="#4EC9B0" FontSize="12" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <!-- No Data Message -->
                                                <TextBlock Grid.Row="2" Grid.ColumnSpan="4" 
                                                           Text="No image data yet. Stats will appear after capturing images."
                                                           Foreground="#909090" FontSize="10" FontStyle="Italic" HorizontalAlignment="Center"
                                                           Visibility="{Binding HasImageStats, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}"/>
                                            </Grid>
                                            </Border>
                                        </Expander>
                                        
                                        <!-- Action Buttons -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="💾 Save Target" Command="{Binding SaveTargetCommand}" Style="{StaticResource ActionButton}" Margin="0,0,12,0"/>
                                            <Button Content="Cancel" Command="{Binding CancelTargetEditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                                            <Button Content="🗑️ Delete Target" Command="{Binding DeleteTargetCommand}" Style="{StaticResource SecondaryButton}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            
                            <!-- No Selection State -->
                            <Border Grid.Column="2" Background="#252526" CornerRadius="4" Padding="20"
                                    Visibility="{Binding HasSelectedTarget, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="👈" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Select a target to view details" Foreground="#C0C0C0" 
                                               HorizontalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- Generate Scheduler Preview Section -->
                <Expander IsExpanded="False" Margin="0,12,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🌙 GENERATE NIGHT PREVIEW" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="12"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border Background="#2D2D30" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Preview what the scheduler would generate using your targets and configuration." 
                                       Foreground="#B0B0B0" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            
                            <!-- Compact Controls Row: Date | Start | Config | Generate -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <!-- Date -->
                                <Button Content="◀" Command="{Binding PreviousPreviewDateCommand}" 
                                        Style="{StaticResource SecondaryButton}" Padding="4,2" FontSize="9"/>
                                <TextBlock Text="{Binding GeneratePreviewDateDisplay}" FontSize="10" FontWeight="SemiBold" 
                                           Foreground="#E0E0E0" VerticalAlignment="Center" Margin="4,0"/>
                                <Button Content="▶" Command="{Binding NextPreviewDateCommand}" 
                                        Style="{StaticResource SecondaryButton}" Padding="4,2" FontSize="9"/>
                                <Button Content="Today" Command="{Binding TodayPreviewDateCommand}" 
                                        Style="{StaticResource SecondaryButton}" Padding="4,2" FontSize="8" Margin="4,0,0,0"/>
                                <!-- Start Time -->
                                <ComboBox ItemsSource="{Binding PreviewStartTimeOptions}"
                                          SelectedValue="{Binding SelectedPreviewStartTime}"
                                          Background="#3C3C3C" Foreground="#E0E0E0" FontSize="10"
                                          MinWidth="60" Padding="4,2" Margin="8,0,0,0"/>
                                <!-- Config -->
                                <ComboBox ItemsSource="{Binding SchedulerConfigurations}"
                                          SelectedValue="{Binding SelectedPreviewConfigId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Background="#3C3C3C" Foreground="#E0E0E0"
                                          FontSize="10" Margin="4,0,0,0" MinWidth="80" MaxWidth="120"/>
                                <!-- Generate -->
                                <Button Content="Generate" 
                                        Command="{Binding GenerateSchedulerPreviewCommand}"
                                        Style="{StaticResource ActionButton}" 
                                        Padding="8,3" FontSize="10" Margin="4,0,0,0"
                                        IsEnabled="{Binding IsLoadingPreview, Converter={StaticResource InverseBoolConverter}}"/>
                            </StackPanel>
                            
                            <!-- Location Warning -->
                            <Border Background="#4A3C00" CornerRadius="3" Padding="8,4" Margin="0,0,0,8"
                                    Visibility="{Binding ShowLocationMismatch, Converter={StaticResource BoolToVisConverter}}">
                                <TextBlock Text="{Binding LocationMismatchWarning}" Foreground="#FFD700" FontSize="9" TextWrapping="Wrap"/>
                            </Border>
                            
                            <!-- Loading Indicator -->
                            <TextBlock Text="Generating preview..." Foreground="#569CD6" FontSize="10" 
                                       HorizontalAlignment="Center" Margin="0,4,0,4"
                                       Visibility="{Binding IsLoadingPreview, Converter={StaticResource BoolToVisConverter}}"/>
                            
                            <!-- Preview Results -->
                            <Border Background="#252526" CornerRadius="4" Padding="8"
                                    Visibility="{Binding HasSchedulerPreview, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel>
                                    <!-- Summary -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SchedulerPreview.Statistics.TotalSessions}" 
                                                       FontSize="16" FontWeight="Bold" Foreground="#4EC9B0" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Sessions" FontSize="9" Foreground="#909090" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SchedulerPreview.Statistics.UniqueTargets}" 
                                                       FontSize="16" FontWeight="Bold" Foreground="#569CD6" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Targets" FontSize="9" Foreground="#909090" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SchedulerPreview.Statistics.TotalPlannedHours, StringFormat='{}{0:F1}h'}" 
                                                       FontSize="16" FontWeight="Bold" Foreground="#D69D29" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Imaging" FontSize="9" Foreground="#909090" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SchedulerPreview.Statistics.UnscheduledHours, StringFormat='{}{0:F1}h'}" 
                                                       FontSize="16" FontWeight="Bold" Foreground="#808080" HorizontalAlignment="Center"/>
                                            <TextBlock FontSize="9" Foreground="#909090" HorizontalAlignment="Center">
                                                <Run Text="Empty (until "/>
                                                <Run Text="{Binding SchedulerPreview.AstronomicalDawn, StringFormat=HH:mm, Mode=OneWay}"/>
                                                <Run Text=")"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Altitude Chart (ABOVE target list) -->
                                    <TextBlock Text="Night Schedule" Foreground="#C0C0C0" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                    <controls:AltitudeChartControl 
                                        Sessions="{Binding SchedulerPreviewSessions}"
                                        SkippedTargets="{Binding SchedulerPreviewSkippedTargets}"
                                        AstronomicalDusk="{Binding SchedulerPreview.AstronomicalDusk}"
                                        AstronomicalDawn="{Binding SchedulerPreview.AstronomicalDawn}"
                                        ChartStartTime="{Binding ChartStartTime}"
                                        SelectedTargetId="{Binding SelectedPreviewTargetId}"
                                        CustomHorizon="{Binding Observatory.CustomHorizonPoints}"
                                        MinAltitude="{Binding SchedulerConfig.MinAltitudeDegrees}"
                                        Height="220"/>
                                    
                                    <!-- Sessions List (BELOW chart) -->
                                    <TextBlock Text="Target Sessions" Foreground="#C0C0C0" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180">
                                        <StackPanel>
                                            <!-- Start of night gap -->
                                            <Border Background="#2A2A2A" CornerRadius="2" Padding="6,2" Margin="0,0,0,1"
                                                    Visibility="{Binding SchedulerPreview.HasStartGap, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock Text="{Binding SchedulerPreview.StartGapDisplay, Mode=OneWay}" FontSize="10" Foreground="#FF9800" 
                                                           FontStyle="Italic" HorizontalAlignment="Left"/>
                                            </Border>
                                            <ItemsControl ItemsSource="{Binding SchedulerPreviewSessions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <!-- Gap indicator (shown if there's a gap before this session) -->
                                                        <Border Background="#2A2A2A" CornerRadius="2" Padding="6,2" Margin="0,0,0,1"
                                                                Visibility="{Binding HasGapBefore, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                                                            <TextBlock Text="{Binding GapDisplay, Mode=OneWay}" FontSize="10" Foreground="#FF9800" 
                                                                       FontStyle="Italic" HorizontalAlignment="Left"/>
                                                        </Border>
                                                        <!-- Session row with left border accent -->
                                                        <Border Background="#1E1E1E" BorderBrush="#4EC9B0" BorderThickness="3,0,0,0" CornerRadius="2" Padding="6,4" Margin="0,0,0,2" Cursor="Hand">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick" 
                                                                              Command="{Binding DataContext.SelectPreviewTargetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                              CommandParameter="{Binding}"/>
                                                            </Border.InputBindings>
                                                            <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="50"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- Time range (local time) -->
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11" Foreground="#A0A0A0" Margin="0,0,8,0">
                                                                        <Run Text="{Binding StartTimeLocal, StringFormat=HH:mm, Mode=OneWay}"/>
                                                                        <Run Text="-"/>
                                                                        <Run Text="{Binding EndTimeLocal, StringFormat=HH:mm, Mode=OneWay}"/>
                                                                    </TextBlock>
                                                                    <!-- Target + Panel -->
                                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Foreground="#E0E0E0" Margin="0,0,8,0">
                                                                        <Run Text="{Binding TargetName}" FontWeight="SemiBold"/>
                                                                        <Run Text="{Binding PanelNumber, StringFormat=' P{0}', TargetNullValue=''}" Foreground="#CE91CE"/>
                                                                    </TextBlock>
                                                                    <!-- Compact filter summary - summed totals per filter (middle) -->
                                                                    <TextBlock Grid.Column="2" Text="{Binding FilterSummary, Mode=OneWay}" 
                                                                               VerticalAlignment="Center" FontSize="10" Foreground="#569CD6" 
                                                                               FontFamily="Consolas" Margin="0,0,8,0"/>
                                                                    <!-- Moon distance -->
                                                                    <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="11" Foreground="#A0A0A0" Margin="0,0,8,0">
                                                                        <Run Text="🌙"/>
                                                                        <Run Text="{Binding MoonDistance, StringFormat='{}{0:F0}°'}"/>
                                                                    </TextBlock>
                                                                    <!-- Duration -->
                                                                    <TextBlock Grid.Column="4" Text="{Binding PlannedImagingMinutes, StringFormat='{}{0:F0}m'}" 
                                                                               FontSize="12" Foreground="#4EC9B0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                                </Grid>
                                                                <TextBlock FontSize="10" Foreground="#8FD3A8" Margin="0,4,0,0">
                                                                    <Run Text="Score "/>
                                                                    <Run Text="{Binding PriorityScore, StringFormat={}{0:F1}, TargetNullValue=-}"/>
                                                                    <Run Text="  "/>
                                                                    <Run Text="{Binding SelectionReason, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- End of night gap -->
                                            <Border Background="#2A2A2A" CornerRadius="2" Padding="6,2" Margin="0,1,0,0"
                                                    Visibility="{Binding SchedulerPreview.HasEndGap, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock Text="{Binding SchedulerPreview.EndGapDisplay, Mode=OneWay}" FontSize="10" Foreground="#FF9800" 
                                                           FontStyle="Italic" HorizontalAlignment="Left"/>
                                            </Border>
                                            
                                            <!-- Unscheduled Slots Info -->
                                            <Border Background="#3A2020" CornerRadius="4" Padding="6" Margin="0,8,0,0"
                                                    Visibility="{Binding HasUnscheduledSlots, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="⚠ Unschedulable Time Slots:" Foreground="#FF8080" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                    <ItemsControl ItemsSource="{Binding SchedulerPreviewUnscheduledSlots}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,1">
                                                                    <TextBlock FontSize="9" Foreground="#C08080" TextWrapping="Wrap">
                                                                        <Run Text="{Binding StartTimeLocal, StringFormat=HH:mm, Mode=OneWay}"/>
                                                                        <Run Text="-"/>
                                                                        <Run Text="{Binding EndTimeLocal, StringFormat=HH:mm, Mode=OneWay}"/>
                                                                        <Run Text=": "/>
                                                                        <Run Text="{Binding Reason, Mode=OneWay}"/>
                                                                    </TextBlock>
                                                                    <TextBlock FontSize="9" Foreground="#C8A0A0" TextWrapping="Wrap"
                                                                               Visibility="{Binding BestCandidateTargetName, Converter={StaticResource NullOrEmptyToVisConverter}}">
                                                                        <Run Text="Best candidate: "/>
                                                                        <Run Text="{Binding BestCandidateTargetName}"/>
                                                                        <Run Text=" (score "/>
                                                                        <Run Text="{Binding BestCandidateTargetScore, StringFormat={}{0:F1}, TargetNullValue=-}"/>
                                                                        <Run Text=")"/>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                    
                                    <!-- Selected Session Info with Exposure Plan -->
                                    <Border Background="#2A3A2A" CornerRadius="4" Padding="8" Margin="0,8,0,0"
                                            Visibility="{Binding HasSelectedPreviewTarget, Converter={StaticResource BoolToVisConverter}}">
                                        <StackPanel>
                                            <TextBlock FontSize="10" Foreground="#90C090" Margin="0,0,0,4">
                                                <Run Text="Selected: "/>
                                                <Run Text="{Binding SelectedPreviewTargetName, Mode=OneWay}" FontWeight="SemiBold"/>
                                                <Run Text=" (click again to deselect)"/>
                                            </TextBlock>
                                            <!-- Filter Progress Details -->
                                            <Border Background="#1E2E1E" CornerRadius="3" Padding="8" Margin="0,4,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="📊 Filter Progress (current→end/goal):" Foreground="#A0C0A0" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding SelectedPreviewSessionFilterProgress, Mode=OneWay}" 
                                                               Foreground="#E0E0E0" FontSize="11" FontFamily="Consolas"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="📋 Sequence:" Foreground="#A0C0A0" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                                    <TextBlock Text="{Binding SelectedPreviewSessionExposurePlan, Mode=OneWay}" 
                                                               Foreground="#E0E0E0" FontSize="10" FontFamily="Consolas"
                                                               TextWrapping="Wrap"/>
                                                    <!-- Meridian Flip Info -->
                                                    <StackPanel Visibility="{Binding SelectedPreviewSessionHasTransit, Converter={StaticResource BoolToVisConverter}}" Margin="0,8,0,0">
                                                        <TextBlock Text="🔄 Meridian:" Foreground="#C0A0C0" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                        <TextBlock Foreground="#E0E0E0" FontSize="10" FontFamily="Consolas">
                                                            <Run Text="Transit: "/>
                                                            <Run Text="{Binding SelectedPreviewSessionTransitTime, Mode=OneWay}" FontWeight="SemiBold"/>
                                                            <Run Text="{Binding SelectedPreviewSessionMeridianFlipWindow, Mode=OneWay}" Foreground="#FFA0A0"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Filter Observability Windows -->
                                            <Border Background="#1E1E2E" CornerRadius="3" Padding="8" Margin="0,6,0,0"
                                                    Visibility="{Binding SelectedTargetFilterObservability, Converter={StaticResource NullOrEmptyToVisConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="🔭 Observable Time Windows by Filter:" Foreground="#A0A0C0" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                    <TextBlock Foreground="#808090" FontSize="9" Margin="0,0,0,6">
                                                        <Run Text="Rise: "/>
                                                        <Run Text="{Binding SelectedTargetFilterObservability.RiseTimeLocal, StringFormat=HH:mm, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text="  Set: "/>
                                                        <Run Text="{Binding SelectedTargetFilterObservability.SetTimeLocal, StringFormat=HH:mm, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text="  Max Alt: "/>
                                                        <Run Text="{Binding SelectedTargetFilterObservability.MaxAltitude, StringFormat={}{0:F1}°, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text=" at "/>
                                                        <Run Text="{Binding SelectedTargetFilterObservability.MaxAltitudeTimeLocal, StringFormat=HH:mm, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <ItemsControl ItemsSource="{Binding SelectedTargetFilterObservability.FilterWindows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,2,0,0">
                                                                    <TextBlock FontSize="10" FontWeight="SemiBold" Margin="0,0,0,2">
                                                                        <Run Text="🔬 " Foreground="#569CD6"/>
                                                                        <Run Text="{Binding Key, Mode=OneWay}" Foreground="#569CD6"/>
                                                                        <Run Text=":" Foreground="#808090"/>
                                                                    </TextBlock>
                                                                    <ItemsControl ItemsSource="{Binding Value}" Margin="16,0,0,0">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock FontSize="9" Foreground="#C0C0C0" Margin="0,1,0,0">
                                                                                    <Run Text="{Binding Display, Mode=OneWay}" FontFamily="Consolas"/>
                                                                                    <Run Text=" - " Foreground="#606060"/>
                                                                                    <Run Text="{Binding EndReason, Mode=OneWay}" Foreground="#808080" FontStyle="Italic"/>
                                                                                </TextBlock>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Skipped Targets Section -->
                                    <Border Background="#3A2A00" CornerRadius="4" Padding="8" Margin="0,8,0,0"
                                            Visibility="{Binding HasSkippedTargets, Converter={StaticResource BoolToVisConverter}}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="⚠ Not Scheduled" Foreground="#FFB800" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SkippedTargetsCount, StringFormat=' ({0} targets)'}" 
                                                           Foreground="#C0A060" FontSize="11"/>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding SchedulerPreviewSkippedTargets}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#2D2D2D" CornerRadius="3" Padding="8,6" Margin="0,0,0,4" Cursor="Hand">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick" 
                                                                              Command="{Binding DataContext.SelectPreviewTargetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                              CommandParameter="{Binding TargetId}"/>
                                                            </Border.InputBindings>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding TargetName}" 
                                                                           Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Reason}" 
                                                                           Foreground="#FFB800" FontSize="10" HorizontalAlignment="Right"/>
                                                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Foreground="#D0C080" FontSize="10" Margin="0,4,0,0"
                                                                           Visibility="{Binding WinningTargetName, Converter={StaticResource NullOrEmptyToVisConverter}}">
                                                                    <Run Text="Score "/>
                                                                    <Run Text="{Binding PriorityScore, StringFormat={}{0:F1}, TargetNullValue=-}"/>
                                                                    <Run Text="  Lost to "/>
                                                                    <Run Text="{Binding WinningTargetName}"/>
                                                                    <Run Text=" ("/>
                                                                    <Run Text="{Binding WinningTargetScore, StringFormat={}{0:F1}, TargetNullValue=-}"/>
                                                                    <Run Text=")"/>
                                                                </TextBlock>
                                                                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding DetailedExplanation}" 
                                                                           Foreground="#A0A0A0" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"
                                                                           Visibility="{Binding DetailedExplanation, Converter={StaticResource NullOrEmptyToVisConverter}}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <!-- Altitude Chart for Selected Skipped Target -->
                                            <StackPanel Visibility="{Binding HasSelectedSkippedTarget, Converter={StaticResource BoolToVisConverter}}" Margin="0,8,0,0">
                                                <TextBlock Text="{Binding SelectedSkippedTargetName, StringFormat='Altitude: {0}'}" 
                                                           Foreground="#FFB800" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <controls:AltitudeChartControl 
                                                    Sessions="{Binding SelectedSkippedTargetAsSessions}"
                                                    SkippedTargets="{x:Null}"
                                                    AstronomicalDusk="{Binding SchedulerPreview.AstronomicalDusk}"
                                                    AstronomicalDawn="{Binding SchedulerPreview.AstronomicalDawn}"
                                                    CustomHorizon="{Binding Observatory.CustomHorizonPoints}"
                                                    MinAltitude="{Binding SchedulerConfig.MinAltitudeDegrees}"
                                                    Height="220"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            
                            <!-- No Results Message -->
                            <TextBlock Text="Select a configuration and click Generate to preview tonight's schedule."
                                       Foreground="#909090" FontSize="10" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,8,0,0"
                                       Visibility="{Binding HasSchedulerPreview, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- Export / Import Targets Section -->
                <Expander IsExpanded="False" Margin="0,12,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦 EXPORT / IMPORT TARGETS" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="12"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border Background="#2D2D30" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                        <StackPanel>
                            <!-- Auto-export option with label -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox IsChecked="{Binding AutoExportAfterSync, Mode=TwoWay}" 
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Auto-export targets after sync" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text=" - Automatically saves targets to file after each sync" Foreground="#909090" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Export path with label -->
                            <TextBlock Text="Export/Import Path:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ExportPath, Mode=TwoWay}" 
                                         Background="#3C3C3C" Foreground="#E0E0E0" BorderBrush="#555" Padding="6,4"/>
                                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseExportPathCommand}" 
                                        Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                            </Grid>
                            
                            <!-- Export/Import buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Targets" Command="{Binding ExportTargetsCommand}" 
                                        Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                                <Button Content="Import Targets" Command="{Binding ImportTargetsCommand}" 
                                        Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- Help & Documentation Section -->
                <Expander IsExpanded="False" Margin="0,12,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❓ HELP &amp; DOCUMENTATION" FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="12"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border Background="#2D2D30" CornerRadius="4" Padding="16" Margin="0,8,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📚 Documentation" Foreground="#4EC9B0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="For installation guides, configuration, troubleshooting, and complete documentation visit:" 
                                       Foreground="#B0B0B0" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,12"/>
                            <Button Command="{Binding OpenDocumentationCommand}" Style="{StaticResource ActionButton}" Padding="12,8" HorizontalAlignment="Center">
                                <TextBlock Text="Open Documentation" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            </Button>
                            <TextBlock Text="N.I.N.A. Plugin section includes installation, configuration, scheduler instruction, loop condition, and troubleshooting guides." 
                                       Foreground="#909090" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>
            
            <!-- NINA-Style Confirmation Dialog Overlay -->
            <Border Background="#80000000" Visibility="{Binding ShowConfirmDialog, Converter={StaticResource BoolToVisConverter}}">
                <Border Background="#2D2D30" BorderBrush="#569CD6" BorderThickness="2" CornerRadius="6" 
                        HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20" MinWidth="300" MaxWidth="400">
                    <StackPanel>
                        <TextBlock Text="{Binding ConfirmDialogTitle}" Foreground="#569CD6" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding ConfirmDialogMessage}" Foreground="#E0E0E0" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Yes" Command="{Binding ConfirmDialogYesCommand}" 
                                    Background="#6B3030" Foreground="White" BorderThickness="0" 
                                    Padding="16,6" Margin="0,0,8,0" Cursor="Hand" FontSize="12" FontWeight="SemiBold"/>
                            <Button Content="No" Command="{Binding ConfirmDialogNoCommand}" 
                                    Background="#505050" Foreground="White" BorderThickness="0" 
                                    Padding="16,6" Cursor="Hand" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
