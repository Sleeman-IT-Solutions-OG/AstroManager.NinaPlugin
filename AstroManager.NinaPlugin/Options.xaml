                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="On Complete" Style="{StaticResource FieldLabel}" ToolTip="What happens when all imaging goals are completed: Continue (keep imaging), Lower Priority (reduce priority), Stop (stop scheduling this target)"/>
