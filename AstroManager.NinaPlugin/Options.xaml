                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerTargetTemplate.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="A descriptive name for this template (e.g., 'Narrowband Faint', 'Bright Galaxy')"/>
