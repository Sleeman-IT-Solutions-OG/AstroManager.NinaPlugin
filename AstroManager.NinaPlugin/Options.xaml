                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                    <ColumnDefinition Width="8"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="Priority" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetA.Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                                <TextBlock Grid.Column="3" Text="Altitude" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="4" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetA.Altitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                            </Grid>
                                                                            <Grid Margin="0,4,0,0">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                    <ColumnDefinition Width="8"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="Obs. Min" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetA.ObservableMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                                <TextBlock Grid.Column="3" Text="Remain" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="4" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetA.RemainingTimeMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                            </Grid>
                                                                            <Grid Margin="0,4,0,0">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                    <ColumnDefinition Width="8"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="Moon °" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetA.MoonDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                                <TextBlock Grid.Column="3" Text="Comp %" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="4" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetA.CompletionPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding SchedulerScorePreviewTargetATotal}" Foreground="#4EC9B0" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                                            <TextBlock Text="{Binding SchedulerScorePreviewTargetABreakdown}" Foreground="#A0A0A0" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="3" Padding="8">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding SchedulerScorePreviewTargetB.Name}" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold"/>
                                                                            <Grid Margin="0,6,0,0">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                    <ColumnDefinition Width="8"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="Priority" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetB.Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                                <TextBlock Grid.Column="3" Text="Altitude" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="4" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetB.Altitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                            </Grid>
                                                                            <Grid Margin="0,4,0,0">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                    <ColumnDefinition Width="8"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="Obs. Min" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetB.ObservableMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                                <TextBlock Grid.Column="3" Text="Remain" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="4" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetB.RemainingTimeMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                            </Grid>
                                                                            <Grid Margin="0,4,0,0">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                    <ColumnDefinition Width="8"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="60"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="Moon °" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="1" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetB.MoonDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                                <TextBlock Grid.Column="3" Text="Comp %" Style="{StaticResource FieldLabel}"/>
                                                                                <TextBox Grid.Column="4" Style="{StaticResource InputBox}" Text="{Binding SchedulerScorePreviewTargetB.CompletionPercentage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding SchedulerScorePreviewTargetBTotal}" Foreground="#4EC9B0" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                                            <TextBlock Text="{Binding SchedulerScorePreviewTargetBBreakdown}" Foreground="#A0A0A0" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Row 3: Filter Pattern, Batch Size, Goal Completion -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Filter Pattern" Style="{StaticResource FieldLabel}" ToolTip="How filters are cycled: Parallel (round robin), Batch (X per filter), Sequential (one filter at a time)"/>
                                                        <ComboBox ItemsSource="{Binding FilterShootingPatternDisplayValues}" 
                                                                  SelectedValue="{Binding ConfigFilterShootingPattern, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"
                                                                  ToolTip="Parallel = cycle filters | Batch = X subs per filter | Sequential = finish one filter"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2"
                                                                Visibility="{Binding IsBatchPatternSelectedForConfig, Converter={StaticResource BoolToVisConverter}}">
                                                        <TextBlock Text="Batch" Style="{StaticResource FieldLabel}" ToolTip="Number of exposures to take per filter before switching (only used in Batch mode)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.FilterBatchSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Exposures per filter (e.g., 5). Only applies to Batch filter pattern."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="On Complete" Style="{StaticResource FieldLabel}" ToolTip="What to do when a target's imaging goals are complete"/>
                                                        <ComboBox ItemsSource="{Binding GoalCompletionBehaviorDisplayValues}" 
                                                                  SelectedValue="{Binding ConfigGoalCompletionBehavior, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"
                                                                  ToolTip="Continue = keep imaging | LowerPriority = reduce priority | Stop = stop scheduling"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="6"
                                                                Visibility="{Binding IsLowerPrioritySelectedForConfig, Converter={StaticResource BoolToVisConverter}}">
                                                        <TextBlock Text="Lower To" Style="{StaticResource FieldLabel}" ToolTip="New priority value when using LowerPriority behavior (1=highest, 99=lowest)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.LowerPriorityTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="New priority (e.g., 50). Only used with LowerPriority behavior."/>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Row 4: Time Limits -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Min Seq (m)" Style="{StaticResource FieldLabel}" ToolTip="Don't schedule a target if available imaging window is shorter than this (prevents very short sessions)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MinSessionDurationMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Minimum sequence in minutes (e.g., 30). Avoids scheduling targets with very short windows."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Max/Night (h)" Style="{StaticResource FieldLabel}" ToolTip="Maximum hours to spend on any single target per night (prevents over-imaging one target)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MaxHoursPerTargetPerNight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Max hours per target per night (e.g., 3). 0 = unlimited."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,2">
                                                        <CheckBox IsChecked="{Binding SelectedSchedulerConfiguration.UseMoonAvoidance, Mode=TwoWay}" VerticalAlignment="Center"
                                                                  ToolTip="Enable moon avoidance globally. Individual filters can have their own moon avoidance profiles."/>
                                                        <TextBlock Text="Moon Avoid" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"
                                                                   ToolTip="Enable moon avoidance"/>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Error Handling Section -->
                                                <TextBlock Text="Error Handling" Foreground="#569CD6" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="No Target Behavior" Style="{StaticResource FieldLabel}" ToolTip="What to do when no targets are available"/>
                                                        <ComboBox ItemsSource="{Binding NoTargetBehaviorValues}" 
                                                                  SelectedValue="{Binding SelectedSchedulerConfiguration.NoTargetBehavior, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#FFFFFF" FontSize="11" Padding="4,2" MinHeight="24"
                                                                  ToolTip="Stop: End sequence. Wait: Check again later. ShootCompleted: Image done targets."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Error Behavior" Style="{StaticResource FieldLabel}" ToolTip="What to do when an imaging error occurs"/>
                                                        <ComboBox ItemsSource="{Binding ErrorBehaviorValues}" 
                                                                  SelectedValue="{Binding SelectedSchedulerConfiguration.ErrorBehavior, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#FFFFFF" FontSize="11" Padding="4,2" MinHeight="24"
                                                                  ToolTip="Stop: End sequence. Wait: Pause then retry. Skip: Move to next target."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Retries" Style="{StaticResource FieldLabel}" ToolTip="Max error retries before applying error behavior"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MaxErrorRetries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Number of retries (1-10) before escalating"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="No Tgt Wait (m)" Style="{StaticResource FieldLabel}" ToolTip="Minutes to wait when no targets (if WaitAndRetry)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.NoTargetWaitMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Wait minutes (1-120) before checking for targets again"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Err Wait (m)" Style="{StaticResource FieldLabel}" ToolTip="Minutes to wait on error (if WaitAndRetry)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.ErrorWaitMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Wait minutes (1-60) before retrying after error"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Skip Dur (m)" Style="{StaticResource FieldLabel}" ToolTip="Minutes to skip target (if SkipTargetTemporarily)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.ErrorSkipDurationMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Skip duration (1-480m) before target is eligible again"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Text="Runtime Stop / Safety Checks" Foreground="#569CD6" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
