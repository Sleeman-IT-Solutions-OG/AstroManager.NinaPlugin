                                                                       Text="{Binding UseMoonAvoidance, Converter={StaticResource BoolToYesNoConverter}, TargetNullValue='-'}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        
                                        <!-- Selected Template Edit Panel -->
                                        <Border Background="#2D2D30" CornerRadius="4" Padding="12" Margin="0,0,0,8"
                                                Visibility="{Binding HasSelectedSchedulerTargetTemplate, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="✏️ EDIT TEMPLATE" Foreground="#D69D29" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
