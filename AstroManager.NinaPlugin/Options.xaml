                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Max RMS" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MaxGuidingRmsArcSec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Max guider total RMS (arcsec)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding SelectedSchedulerConfiguration.EnableCloudCoverCheck, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Clouds" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="6">
                                                        <TextBlock Text="Max Cloud %" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MaxCloudCoverPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Max cloud cover %"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding SelectedSchedulerConfiguration.EnableRainRateCheck, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Rain" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Max Rain" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MaxRainRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Max rain rate (device units)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Min Alt (°)" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MinMountAltitudeDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Do not slew below this altitude"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding SelectedSchedulerConfiguration.EnableCoolerPowerCheck, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Cooler Power" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" TextWrapping="Wrap"/>
