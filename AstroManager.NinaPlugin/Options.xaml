                                                                <Button Command="{Binding DataContext.DeleteMoonAvoidanceProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                                        CommandParameter="{Binding}" Background="#6B3030" Foreground="#E0E0E0" BorderThickness="0" 
                                                                        Padding="8,5" Cursor="Hand" ToolTip="Delete"
                                                                        Visibility="{Binding IsSystemDefault, Converter={StaticResource InverseBoolToVisConverter}}">
                                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                                </Button>
                                                                <!-- Show lock icon for system defaults -->
                                                                <TextBlock Text="🔒" FontSize="12" Foreground="#909090" VerticalAlignment="Center" Margin="4,0,0,0"
