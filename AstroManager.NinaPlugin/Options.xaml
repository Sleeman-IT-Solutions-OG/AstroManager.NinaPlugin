                                                        <CheckBox IsChecked="{Binding SelectedSchedulerConfiguration.EnableSafetyMonitorCheck, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Check safety monitor" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
