                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="8"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="3" Padding="8">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding SchedulerScorePreviewTargetA.Name}" Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold"/>
