                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="6" Text="{Binding GoalCompletionBehaviour, Mode=OneWay, Converter={StaticResource GoalCompletionDisplayConverter}}" Foreground="#909090" FontSize="10" 
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
