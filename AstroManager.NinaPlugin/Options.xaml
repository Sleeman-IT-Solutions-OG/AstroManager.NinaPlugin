                                                                <Button Command="{Binding DataContext.CopyMoonAvoidanceProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                                        CommandParameter="{Binding}" Background="#505050" Foreground="#E0E0E0" BorderThickness="0" 
                                                                        Padding="8,5" Margin="0,0,4,0" Cursor="Hand" ToolTip="Copy profile">
                                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                                </Button>
