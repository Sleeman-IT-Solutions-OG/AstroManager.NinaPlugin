                                                                 ToolTip="Minimum sequence duration in minutes (e.g., 30). Leave empty to use scheduler default."/>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Row 3: On Complete, Lower To Priority, Goal Order, Batch Size -->
