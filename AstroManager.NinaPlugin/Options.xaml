                                                                  SelectedValue="{Binding TemplateGoalCompletionBehaviour, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"
                                                                  ToolTip="Continue = keep imaging | Lower Priority = reduce priority | Stop = stop scheduling"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2"
                                                                Visibility="{Binding IsLowerPrioritySelectedForTemplate, Converter={StaticResource BoolToVisConverter}}">
                                                        <TextBlock Text="Lower To" Style="{StaticResource FieldLabel}" ToolTip="New priority value after goals complete (1-99, higher = lower priority)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerTargetTemplate.LowerPriorityTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="New priority after goals complete (e.g., 50)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Goal Order" Style="{StaticResource FieldLabel}" ToolTip="How imaging goals/filters are cycled: Parallel (round robin), Batch (X per filter), Sequential (one filter at a time)"/>
                                                        <ComboBox ItemsSource="{Binding FilterShootingPatternDisplayValues}" 
                                                                  SelectedValue="{Binding TemplateFilterShootingPattern, Mode=TwoWay}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                                                  Background="#3C3C3C" Foreground="#E0E0E0" FontSize="12" Padding="4,3" MinHeight="26"
                                                                  ToolTip="Parallel = cycle filters | Batch = X subs per filter | Sequential = finish one filter"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="6"
                                                                Visibility="{Binding IsBatchPatternSelectedForTemplate, Converter={StaticResource BoolToVisConverter}}">
                                                        <TextBlock Text="Batch" Style="{StaticResource FieldLabel}" ToolTip="Number of exposures per filter before switching (only for Batch mode)"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerTargetTemplate.FilterBatchSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Exposures per filter (e.g., 5)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="8" Width="70">
                                                        <TextBlock Text="Dither X" Style="{StaticResource FieldLabel}" ToolTip="Dither every X exposures. 0 = disabled. Can be overridden by Exposure Template."/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerTargetTemplate.DitherEveryX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Dither every X exposures (0 = disabled)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="9" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,2">
                                                        <CheckBox IsChecked="{Binding SelectedSchedulerTargetTemplate.UseMoonAvoidance, Mode=TwoWay}" VerticalAlignment="Center"
                                                                  ToolTip="Enable moon avoidance for targets using this template. Filters will use their individual moon avoidance profiles."/>
                                                        <TextBlock Text="Moon Avoid" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"
                                                                   ToolTip="Enable moon avoidance for targets using this template"/>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Row 4: Moon Phase Range -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Min Moon %" Style="{StaticResource FieldLabel}" ToolTip="Minimum moon illumination percentage (0-100). Target won't be scheduled below this moon phase."/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerTargetTemplate.MinMoonPhasePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Minimum moon phase percentage (e.g., 0 for new moon)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Max Moon %" Style="{StaticResource FieldLabel}" ToolTip="Maximum moon illumination percentage (0-100). Target won't be scheduled above this moon phase."/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerTargetTemplate.MaxMoonPhasePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Maximum moon phase percentage (e.g., 50 for half moon)"/>
                                                    </StackPanel>
                                                </Grid>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Button Content="💾 Save" Command="{Binding SaveSchedulerTargetTemplateCommand}" Style="{StaticResource ActionButton}" Margin="0,0,8,0" Padding="12,6" FontSize="12"/>
                                                    <Button Content="Cancel" Command="{Binding CloseSchedulerTargetTemplateEditCommand}" Style="{StaticResource SecondaryButton}" Padding="12,6" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    
                                    <!-- Moon Avoidance Content -->
                                    <StackPanel Visibility="{Binding IsMoonAvoidanceSelected, Converter={StaticResource BoolToVisConverter}}">
