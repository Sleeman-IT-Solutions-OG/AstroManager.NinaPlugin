                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Min Alt (°)" Style="{StaticResource FieldLabel}" ToolTip="Minimum altitude in degrees above horizon. Target won't be scheduled below this altitude. Leave empty to use scheduler default."/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerTargetTemplate.MinAltitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
