                                                        <TextBlock Text="Max Cooler %" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerConfiguration.MaxCoolerPowerPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Cooler power threshold %"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="8">
                                                        <TextBlock Text="Warmup Δ°C" Style="{StaticResource FieldLabel}"/>
