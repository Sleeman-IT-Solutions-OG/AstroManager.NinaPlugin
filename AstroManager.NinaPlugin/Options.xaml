                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}" ToolTip="Optional notes about when to use this template"/>
                                                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SelectedSchedulerTargetTemplate.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Optional notes about when to use this template"/>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Row 2: Min Alt, Max Hrs/Night, Min Sequence, Max Sequence -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
