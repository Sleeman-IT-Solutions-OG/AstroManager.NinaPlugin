                                                <TextBlock Grid.Column="2" Text="Full Moon°" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="3" Text="Width" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="4" Text="Min Alt" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"/>
                                            </Grid>
